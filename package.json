{
  "name": "mesh-komp",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "start": "node --env-file .env src/server.js",
    "monitor:web": "node --env-file .env ccmon-server.js",
    "bench:compression": "node benchmarks/compression-benchmark.js",
    "bench:compression:save": "node benchmarks/compression-benchmark.js --save",
    "test": "node --test --test-force-exit --test-timeout=120000",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "keywords": [
    "mesh",
    "ide",
    "ai",
    "coding-assistant"
  ],
  "author": "Edgar Baumann",
  "license": "ISC",
  "description": "Mesh AI — browser-based AI-powered IDE with integrated terminal, AI chat, voice, and workspace management",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1030.0",
    "@aws-sdk/client-cloudwatch": "^3.1030.0",
    "@aws-sdk/client-dynamodb": "^3.1030.0",
    "@aws-sdk/client-polly": "^3.1030.0",
    "@aws-sdk/client-s3": "^3.1030.0",
    "@aws-sdk/client-transcribe-streaming": "^3.1030.0",
    "@aws-sdk/lib-dynamodb": "^3.1030.0",
    "@aws-sdk/s3-request-presigner": "^3.1030.0",
    "animejs": "^4.3.6",
    "better-sqlite3": "^11.10.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.5.10",
    "highlight.js": "^11.11.1",
    "html-minifier-terser": "^7.2.0",
    "http-proxy": "^1.18.1",
    "ini": "^6.0.0",
    "marked": "^17.0.5",
    "neo-blessed": "^0.2.0",
    "node-pty": "^1.1.0",
    "node-sql-parser": "^5.4.0",
    "pptxgenjs": "^4.0.1",
    "terser": "^5.46.1",
    "toml": "^4.1.1",
    "tree-sitter": "^0.21.1",
    "tree-sitter-css": "^0.21.1",
    "tree-sitter-go": "^0.21.2",
    "tree-sitter-html": "^0.23.2",
