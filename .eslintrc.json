{
  "env": {
    "node": true,
    "es2021": true,
    "browser": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "globals": {
    "d3": "readonly",
    "monaco": "readonly",
    "marked": "readonly",
    "DOMPurify": "readonly",
    "idbKeyval": "readonly",
    "applySettingsTheme": "readonly",
    "anime": "readonly",
    "lottie": "readonly",
    "hljs": "readonly"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-undef": "error",
    "no-empty": "warn",
    "no-constant-condition": "warn",
    "no-inner-declarations": "warn",
    "no-redeclare": "error",
    "no-case-declarations": "warn",
    "no-useless-escape": "warn"
  },
  "ignorePatterns": [
    "node_modules/",
    "old/",
    "output/",
    "test/fixtures/",
    "assets/libs/",
    "mesh-functions/node_modules/",
    "*.min.js"
  ]
}
