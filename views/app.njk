<script>
(function () {
  function initCiDrop(wrapId, btnId, menuId, hiddenSelId, labelId) {
    var wrap = document.getElementById(wrapId);
    var btn  = document.getElementById(btnId);
    var menu = document.getElementById(menuId);
    var sel  = document.getElementById(hiddenSelId);
    var lbl  = document.getElementById(labelId);
    if (!wrap || !btn || !menu || !sel || !lbl) return;

    function open() {
      menu.classList.add('is-open');
      btn.setAttribute('aria-expanded', 'true');
    }
    function close() {
      menu.classList.remove('is-open');
      btn.setAttribute('aria-expanded', 'false');
    }

    btn.addEventListener('click', function (e) {
      e.stopPropagation();
      menu.classList.contains('is-open') ? close() : open();
    });

    menu.addEventListener('click', function (e) {
      var opt = e.target.closest('.ci-opt');
      if (!opt) return;
      var val = opt.dataset.val;
      // Update label and hidden select
      lbl.textContent = opt.textContent;
      sel.value = val;
      // Fire change event so existing listeners react
      sel.dispatchEvent(new Event('change', { bubbles: true }));
      // Update active highlight
      menu.querySelectorAll('.ci-opt').forEach(function (o) {
        o.classList.toggle('ci-opt-active', o.dataset.val === val);
      });
      close();
    });

    // Close on outside click
    document.addEventListener('click', function (e) {
      if (!wrap.contains(e.target)) close();
    });

    // Close on Escape
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') close();
    });

    // Keep custom UI in sync if hidden select is changed programmatically
    sel.addEventListener('change', function () {
      var activeOpt = menu.querySelector('.ci-opt[data-val="' + sel.value + '"]');
      if (activeOpt) {
        lbl.textContent = activeOpt.textContent;
        menu.querySelectorAll('.ci-opt').forEach(function (o) {
          o.classList.toggle('ci-opt-active', o.dataset.val === sel.value);
        });
      }
    });
  }

  document.addEventListener('DOMContentLoaded', function () {
    initCiDrop('modeDropWrap',  'modeDropBtn',  'modeDropMenu',  'chatMode',  'modeDropLabel');
    initCiDrop('modelDropWrap', 'modelDropBtn', 'modelDropMenu', 'chatModel', 'modelDropLabel');
  });
})();
</script>
