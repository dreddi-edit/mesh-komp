  // We watch the attribute change and animate once it becomes visible.
  var scr = document.getElementById('welcomeScr');
  if (scr) {
    var inner = scr.querySelector('.welcome-in');
    if (inner) {
      var welcomed = false;
      function runWelcomeAnim() {
        if (welcomed) return;
        welcomed = true;
        var items = Array.from(inner.children);
        // anime.js v4: animate(targets, params) — no longer a callable function
        window.anime.animate(items, {
          opacity: [0, 1],
          translateY: [20, 0],
          scale: [0.95, 1],
          delay: window.anime.stagger(65, { start: 40 }),
          duration: 500,
          ease: 'spring(1, 85, 14, 0)',
        });
      }

      var obs = new MutationObserver(function () {
        if (scr.style.display && scr.style.display !== 'none') {
          obs.disconnect();
          // one rAF to let the browser paint display:grid before animating
          requestAnimationFrame(runWelcomeAnim);
        }
      });
      obs.observe(scr, { attributes: true, attributeFilter: ['style'] });
    }
  }

  // ── Chat message pop-in ──
  var chatMsgs = document.getElementById('chatMsgs');
  if (chatMsgs) {
    new MutationObserver(function (mutations) {
      mutations.forEach(function (m) {
        m.addedNodes.forEach(function (node) {
          if (node.nodeType !== 1 || !node.classList.contains('msg') || node.id === 'typEl') return;
          // anime.js v4: animate(targets, params)
          window.anime.animate(node, {
            opacity: [0, 1],
            translateY: [10, 0],
            scale: [0.97, 1],
            duration: 280,
            ease: 'spring(1, 100, 16, 0)',
          });
        });
      });
    }).observe(chatMsgs, { childList: true });
  }
})();
</script>

{% endblock %}
