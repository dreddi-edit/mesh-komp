{% extends "layouts/base.njk" %}

{% block title %}Mesh. — IDE{% endblock %}

{% block head %}
<style>
  #page-transition-overlay {
    position: fixed; inset: 0; background: #fff; z-index: 9999; pointer-events: none;
    animation: page-fade-in 700ms ease-in-out 80ms both;
  }
  @keyframes page-fade-in { from { opacity: 1; } to { opacity: 0; } }
</style>


<script>
  (function() {
    var p = window.location.pathname;
    if (p.endsWith('.html')) {
      var newP = p.replace(/\.html$/, '');
      if (newP.endsWith('/index')) newP = newP.slice(0, -6);
      history.replaceState(null, '', newP + window.location.search + window.location.hash);
    }
  })();
</script>
<link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@xterm/xterm@5.5.0/css/xterm.min.css">
<link rel="stylesheet" href="/assets/app-workspace.css?v=20260408b">
<script src="https://cdn.jsdelivr.net/npm/marked@12/marked.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/dompurify@3/dist/purify.min.js"></script>
<script src="/assets/dom-utils.js"></script>
<script src="https://cdn.jsdelivr.net/npm/d3@7.9.0/dist/d3.min.js" defer></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/bodymovin/5.12.2/lottie.min.js" defer></script>
<script src="/assets/app-graph.js?v=20260415f" defer></script>
<style>
/* ── Antigravity-style additions ── */
.tb-text-btn{font-size:.75rem;color:var(--tx3);padding:3px 10px;border-radius:3px;white-space:nowrap;-webkit-app-region:no-drag}
.tb-text-btn:hover{color:var(--txw);background:var(--bg4)}

/* Welcome screen — Antigravity layout */
.welcome-in{display:flex;flex-direction:column;align-items:center;gap:14px;width:100%;max-width:400px;padding:0 20px}
.welcome-logo{display:flex;flex-direction:column;align-items:center;gap:12px;margin-bottom:8px}
.welcome-logo svg{filter:drop-shadow(0 0 20px rgba(0,152,255,.15))}
.welcome-wordmark{font-size:1.6rem;font-weight:600;color:var(--txw);letter-spacing:-.01em}
.w-btn-primary{display:flex;align-items:center;justify-content:center;gap:8px;width:100%;max-width:380px;padding:9px 0;background:var(--ac);color:#fff;font-weight:600;font-size:.85rem;border-radius:3px;border:none;cursor:pointer}
.w-btn-primary:hover{background:var(--ac2)}
.w-btn-row{display:flex;gap:8px;width:100%;max-width:380px}
.w-btn-secondary{flex:1;display:flex;align-items:center;justify-content:center;gap:6px;padding:7px 12px;background:var(--bg3);border:1px solid var(--bd);color:var(--tx2);font-size:.78rem;font-weight:500;border-radius:3px;cursor:pointer}
.w-btn-secondary:hover{border-color:var(--bdhov);color:var(--txw);background:var(--bg4)}
.workspaces{width:100%;max-width:380px;margin-top:4px}
.workspaces-title{font-size:.78rem;font-weight:600;color:var(--txw);margin-bottom:6px}
.ws-item{display:flex;flex-direction:column;padding:10px 14px;background:var(--bg2);border:1px solid var(--bd);border-radius:4px;cursor:pointer;gap:2px}
.ws-item+.ws-item{margin-top:4px}
.ws-item:hover{border-color:var(--bdhov);background:var(--bg3)}
.ws-name{font-size:.82rem;font-weight:500;color:var(--txw)}
.ws-path{font-size:.7rem;color:var(--tx3);font-family:var(--m)}

/* Explorer empty state — Antigravity style */
.sb-no-folder-wrap{padding:12px 16px;display:flex;flex-direction:column;gap:8px}
.sb-no-folder-title{font-size:.72rem;font-weight:600;color:var(--txw);margin-bottom:2px}
.sb-no-folder-desc{font-size:.75rem;color:var(--tx3);line-height:1.5}
.sb-open-btn{display:block;width:100%;padding:6px 12px;background:var(--ac);color:#fff;font-size:.78rem;font-weight:600;border:none;border-radius:3px;cursor:pointer;text-align:center}
.sb-open-btn:hover{background:var(--ac2)}
.sb-clone-btn{display:block;width:100%;padding:6px 12px;background:var(--bg3);color:var(--tx2);font-size:.78rem;font-weight:500;border:1px solid var(--bd);border-radius:3px;cursor:pointer;text-align:center}
.sb-clone-btn:hover{border-color:var(--bdhov);color:var(--txw)}
.sb-restore-btn{display:block;width:100%;padding:6px 12px;background:var(--bg3);color:var(--tx2);font-size:.78rem;font-weight:500;border:1px solid var(--bd);border-radius:3px;cursor:pointer;text-align:center}
.sb-restore-btn:hover{border-color:var(--bdhov);color:var(--txw)}

/* Agent panel header */
.agent-hdr{display:flex;align-items:center;padding:0 10px;height:35px;border-bottom:1px solid var(--bd);flex-shrink:0;gap:6px}
.agent-hdr-title{font-size:.72rem;font-weight:600;color:var(--txw);flex:1}
.agent-hdr-actions{display:flex;gap:2px}
.aha{width:24px;height:24px;display:grid;place-items:center;border-radius:4px;color:var(--tx3);font-size:.82rem;cursor:pointer;border:none;background:none}
.aha:hover{background:var(--bg3);color:var(--txw)}

/* Auth notice in agent panel */
.agent-auth-notice{display:flex;flex-direction:column;gap:6px;padding:20px 14px}
.agent-auth-title{font-size:.85rem;font-weight:600;color:var(--txw)}
.agent-auth-sub{font-size:.75rem;color:var(--tx3);line-height:1.5}

/* Misc from original */
.sb-section{padding:0 12px 0 20px}
.sb-section-title{font-size:.72rem;font-weight:600;color:var(--txw);padding:8px 0 4px;display:flex;align-items:center;gap:4px;cursor:pointer;user-select:none}
.sb-section-title svg{flex-shrink:0}
.sb-desc{font-size:.78rem;color:var(--tx3);line-height:1.55;padding:2px 0 8px}
.sb-acc-sections{border-top:1px solid var(--bd);margin-top:auto;flex-shrink:0}
.sb-acc-row{display:flex;align-items:center;padding:6px 12px 6px 10px;font-size:.72rem;font-weight:600;color:var(--txw);cursor:pointer;gap:4px;user-select:none;border-top:1px solid var(--bd)}
.sb-acc-row:first-child{border-top:none}
.sb-acc-row:hover{background:var(--bg3)}
.sb-acc-chevron{font-size:.65rem;color:var(--tx3);width:14px;text-align:center}
.ext-icon{width:32px;height:32px;border-radius:4px;background:var(--bg4);display:grid;place-items:center;flex-shrink:0;font-size:.7rem;font-weight:700;color:var(--ac)}
.ext-info{min-width:0}
.ext-name{font-size:.78rem;font-weight:600;color:var(--txw)}
.ext-meta{font-size:.65rem;color:var(--tx3)}
.scm-changes-hdr{padding:10px 6px 4px;font-size:.63rem;font-weight:600;text-transform:uppercase;letter-spacing:.05em;color:var(--tx3);display:flex;align-items:center;gap:4px}
.scm-changes-badge{font-size:.6rem;background:var(--bg4);color:var(--txw);padding:0 5px;border-radius:8px;font-weight:600}
.scm-change-list{padding:0 3px}
.scm-file{display:flex;align-items:center;padding:2px 8px;font-size:.75rem;border-radius:3px;cursor:pointer;gap:4px}
.scm-file:hover{background:var(--bg3)}
.scm-file-name{flex:1;color:var(--tx2);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.scm-file-status{font-size:.65rem;font-weight:700;width:16px;text-align:center;flex-shrink:0}
.scm-file-status.scm-m{color:var(--org)}.scm-file-status.scm-u{color:var(--grn)}.scm-file-status.scm-d{color:var(--red)}
.bp-term-type{display:flex;align-items:center;gap:4px;font-size:.72rem;color:var(--tx3);padding:0 8px;border-right:1px solid var(--bd);margin-right:4px}
.stb-dot{display:inline-block;width:7px;height:7px;border-radius:50%;margin-right:3px}
.stb-dot-red{background:var(--red)}.stb-dot-grn{background:var(--grn)}.stb-dot-org{background:var(--org)}
.stb-auth{background:rgba(0,0,0,.2);padding:0 8px;font-weight:600}
.marketplace-view{flex:1;display:none;background:var(--bg)}
.marketplace-view.is-active{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;padding:40px}
.mp-icon{width:64px;height:64px;border-radius:12px;background:var(--bg2);border:1px solid var(--bd);display:grid;place-items:center;font-size:1.5rem;color:var(--ac)}
.mp-title{font-size:1.1rem;font-weight:600;color:var(--txw)}
.mp-desc{font-size:.82rem;color:var(--tx3);text-align:center;max-width:380px;line-height:1.5}
</style>
{% endblock %}


{% block content %}

<div id="page-transition-overlay"></div>

<!-- AUTH -->
<div id="authOverlay" class="auth-overlay is-visible">
<div class="auth-box">
  <div class="auth-logo"><svg width="118" height="28" viewBox="0 0 260 60" fill="none"><g transform="scale(1.5)"><path d="M10 10L5 20L10 30" stroke="var(--ac)" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/><path d="M30 10L35 20L30 30" stroke="var(--ac2)" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/></g><text x="68" y="46" font-family="inherit" font-weight="700" font-size="44" fill="currentColor">Mesh.</text></svg></div>
  <h2>Welcome back</h2><p class="auth-sub">Sign in to your workspace</p>
  <form id="loginForm"><label>Email</label><input type="email" id="emailIn" placeholder="edgar@test.com" required><label>Password</label><input type="password" id="pwIn" placeholder="••••••" required><button type="submit" class="auth-btn" id="loginBtn">Sign in</button></form>
  <p id="loginErr" class="auth-err"></p>
</div>
</div>

<!-- IDE -->
<div class="ide" id="ide">

<!-- TOP BAR — Antigravity style: title center, agent button right -->
<div class="top-bar">
  <div class="tb-l">
    <div class="tb-traffic"><span class="dot-r"></span><span class="dot-y"></span><span class="dot-g"></span></div>
    <span class="tb-title" id="tbTitle">Mesh. — untitled</span>
  </div>
  <div class="tb-c">
    <div class="tb-surface-switch" role="tablist" aria-label="Workspace surface">
      <button class="tb-surface is-active" id="btnSurfaceEditor" data-surface="editor" role="tab" aria-selected="true">Editor</button>
      <button class="tb-surface" id="btnSurfaceTerminal" data-surface="terminal" role="tab" aria-selected="false">Terminal</button>
      <button class="tb-surface" id="btnSurfaceVoice" data-surface="voice" role="tab" aria-selected="false">Voice-Coding</button>
    </div>
  </div>
  <div class="tb-r">
    <button class="tb-text-btn" data-action="Open Agent Manager" id="btnOpenAgentMgr">Open Agent Manager</button>
    <button class="tb-icon" title="Split Panes" data-action="Split Editor"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="18" rx="1"/><rect x="14" y="3" width="7" height="18" rx="1"/></svg></button>
    <button class="tb-icon" title="Command Palette (⌘⇧P)" data-action="Command Palette"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg></button>
    <button class="tb-icon" id="btnToggleSB" title="Toggle Sidebar (⌘B)"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="9" y1="3" x2="9" y2="21"/></svg></button>
    <button class="tb-icon" id="btnToggleChat" title="Toggle Agent Panel"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg></button>
    <button class="tb-icon" id="btnGSearch" title="Search (⌘⇧F)"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></button>
    <button class="tb-icon" id="btnTopSettings" title="Settings (⌘,)"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.6 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.6a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg></button>
    <button class="tb-icon" id="abUser2" title="Account" style="font-size:.7rem;font-weight:700;color:var(--txw)">E</button>
  </div>
</div>

<!-- ACTIVITY BAR -->
<aside class="act-bar">
  <button class="ab is-active" data-panel="explorer" title="Explorer (⌘⇧E)"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg></button>
  <button class="ab" data-panel="search" title="Search (⌘⇧F)"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></button>
  <button class="ab" data-panel="scm" title="Source Control (⌘⇧G)"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M6 21V9a9 9 0 0 0 9 9"/></svg><span class="ab-badge" id="scmBadge">4</span></button>
  <button class="ab" data-panel="debug" title="Run & Debug"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="5 3 19 12 5 21 5 3"/></svg></button>
  <button class="ab" data-panel="extensions" title="Extensions"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg></button>
  <button class="ab" id="abGraph" title="Workspace Mesh Graph (Netz)"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="3"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="M4.93 4.93l1.41 1.41"/><path d="M17.66 17.66l1.41 1.41"/><path d="M4.93 19.07l1.41-1.41"/><path d="M17.66 6.34l1.41-1.41"/></svg></button>
  <div class="ab-spacer"></div>
  <button class="ab" id="abOps" title="Operations"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg></button>
  <button class="ab" id="abSettings" title="Settings (⌘,)"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.6 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.6a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg></button>
  <button class="ab ab-avatar" id="abUser">E</button>
</aside>

<!-- SIDEBAR -->
<div class="sidebar" id="sidebar">
  <!-- Explorer — Antigravity-style empty state -->
  <div class="sb-p is-active" data-panel="explorer">
    <div class="sb-hdr"><span>EXPLORER</span><div class="sb-acts">
      <button class="sa" id="btnNewFile" title="New File"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg></button>
      <button class="sa" id="btnNewFolder" title="New Folder"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/><line x1="12" y1="11" x2="12" y2="17"/><line x1="9" y1="14" x2="15" y2="14"/></svg></button>
      <button class="sa" id="btnRefresh" title="Refresh Explorer"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg></button>
      <button class="sa" id="btnCollapseAll" title="Collapse All"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="8" y1="12" x2="16" y2="12"/></svg></button>
      <button class="sa" id="btnOpenFolder" title="Open Folder"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg></button>
    </div></div>
    <div class="sb-tree" id="fileTree">
      <!-- Antigravity-style no-folder empty state -->
      <div id="emptyExp">
        <div class="sb-no-folder-wrap">
          <div class="sb-no-folder-title">No Folder Opened</div>
          <p class="sb-no-folder-desc">You have not yet opened a folder.</p>
          <button class="sb-open-btn" id="btnOpen2">Open Folder</button>
          <p class="sb-no-folder-desc" style="margin-top:4px">You can clone a repository locally.</p>
          <button class="sb-clone-btn" id="btnCloneSidebar">Clone Repository</button>
          <button class="sb-restore-btn sb-link-restore" id="btnRestore2" style="display:none;margin-top:4px">Restore Last Workspace</button>
        </div>
      </div>
    </div>
    <div class="sb-foot" id="fileFoot" style="display:none"><span id="fileNum">0 files</span><span id="scanProg" style="display:none;color:var(--ac)">scanning…</span></div>
    <div class="sb-acc"><button class="sb-acc-h" data-acc="outline">▸ OUTLINE</button><div class="sb-acc-body" data-acc="outline"><div class="sb-empty-sm">Open a file to see its outline.</div></div></div>
    <div class="sb-acc"><button class="sb-acc-h" data-acc="timeline">▸ TIMELINE</button><div class="sb-acc-body" data-acc="timeline"><div class="sb-empty-sm">File change history.</div></div></div>
  </div>
  <!-- Search -->
  <div class="sb-p" data-panel="search"><div class="sb-hdr"><span>SEARCH</span></div><div class="sb-body"><input class="sb-input" placeholder="Search files by name…" id="searchIn"><div id="searchOut" class="sb-results"></div></div></div>
  <!-- SCM -->
  <div class="sb-p" data-panel="scm"><div class="sb-hdr"><span>SOURCE CONTROL</span></div><div class="sb-body scm-body">
    <div class="scm-branch"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M6 21V9a9 9 0 0 0 9 9"/></svg><span id="branchName">main</span></div>
    <div class="scm-row"><input id="commitMsg" class="sb-input" placeholder="Commit message…"><button class="scm-btn" id="btnCommit">✓ Commit</button></div>
