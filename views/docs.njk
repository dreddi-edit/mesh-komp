{% extends "layouts/base.njk" %}

{% block title %}Dokumentation - Mesh{% endblock %}

{% block head %}
<link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Berkeley+Mono&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <script>
    (function() {
      var p = window.location.pathname;
      if (p.endsWith('.html')) {
        history.replaceState(null, '', p.replace(/\.html$/, '') + window.location.search + window.location.hash);
      }
    })();
  </script>
  <link rel="stylesheet" href="/assets/mesh-docs.css"/>
  <style>
    :root {
      --primary: #0f6a7b;
      --primary-deep: #123f5c;
      --secondary: #5f95a8;
      --tertiary: #1f496b;
      --surface: #f7fbfd;
      --surface-low: #ffffff;
      --surface-mid: #eef5f8;
      --ink: #102432;
      --ink-soft: #607787;
      --outline: #9bb0bc;
    }

    #bg-canvas { position: fixed; inset: 0; z-index: 0; pointer-events: none; }
    
    body::before {
      content: "";
      position: fixed;
      inset: 0;
      z-index: 1;
      pointer-events: none;
      opacity: 0.02;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    }

    /* ── Nav (Override) ── */
    .docs-nav {
      position: fixed;
      top: 16px;
      left: 50%;
      transform: translateX(-50%);
      right: auto;
      width: auto;
      max-width: 720px;
      height: auto;
      padding: 8px 8px 8px 20px;
      background: rgba(255, 255, 255, 0.06);
      backdrop-filter: blur(20px) saturate(150%);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 999px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.25);
      z-index: 100;
      display: flex;
      align-items: center;
      gap: 4px;
      transition: background 0.4s ease, border-color 0.4s ease, box-shadow 0.4s ease;
    }

    .nav-logo img { height: 20px; filter: brightness(0) invert(1); transition: filter 0.4s ease; }
    .nav-divider { width: 1px; height: 16px; background: rgba(255,255,255,0.2); margin: 0 6px; }
    .nav-links a { font-size: 0.76rem; font-weight: 500; color: rgba(255, 255, 255, 0.6); padding: 6px 12px; border-radius: 999px; transition: 0.2s; }
    .nav-links a:hover { color: rgba(255, 255, 255, 0.95); background: rgba(255, 255, 255, 0.08); }
    .nav-links a.active { color: #fff; background: rgba(255, 255, 255, 0.1); }
    .nav-btn-primary { font-size: 0.76rem; font-weight: 600; color: #fff; padding: 7px 16px; border-radius: 999px; background: rgba(15, 106, 123, 0.5); backdrop-filter: blur(10px); }
    
    .docs-nav.scrolled {
      background: rgba(255, 255, 255, 0.82);
      backdrop-filter: blur(20px) saturate(180%);
      border-color: rgba(0, 0, 0, 0.06);
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    }
    .docs-nav.scrolled .nav-logo img { filter: none; }
    .docs-nav.scrolled .nav-links a { color: rgba(16, 36, 50, 0.55); }
    .docs-nav.scrolled .nav-links a:hover { color: #102432; background: rgba(15, 106, 123, 0.06); }
    .docs-nav.scrolled .nav-links a.active { color: #0f6a7b; background: rgba(15, 106, 123, 0.08); }
    .docs-nav.scrolled .nav-btn-primary { background: linear-gradient(135deg, #0f6a7b, #123f5c); }

    /* ── Hero (Override mesh-docs.css) ── */
    .hero {
      width: 100% !important;
      max-width: none !important;
      margin: 0 0 64px 0 !important;
      padding: 160px 24px 100px !important;
      border-radius: 0 !important;
      background: linear-gradient(180deg, #070e14 0%, #0d1f2d 50%, #1a3a4a 75%, #f7fbfd 100%) !important;
      box-shadow: none !important;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .hero::after {
      content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 25%;
      background: linear-gradient(180deg, transparent, var(--surface)); z-index: 3; pointer-events: none;
    }

    .hero-aurora { position: absolute; inset: -40% -20%; filter: blur(70px); opacity: 0.6; z-index: 0; }
    .aurora-band { position: absolute; border-radius: 50%; opacity: 0.5; }
    .aurora-band-1 { width: 120%; height: 45%; top: -10%; left: -10%; background: radial-gradient(ellipse at 30% 50%, rgba(15,106,123,0.35) 0%, transparent 70%); animation: aurora-flow-1 16s ease-in-out infinite; }
    .aurora-band-2 { width: 90%; height: 50%; top: 20%; right: -15%; background: radial-gradient(ellipse at 70% 40%, rgba(31,73,107,0.3) 0%, transparent 70%); animation: aurora-flow-2 20s ease-in-out infinite; }
    .aurora-band-3 { width: 100%; height: 55%; bottom: -15%; left: 5%; background: radial-gradient(ellipse at 50% 60%, rgba(95,149,168,0.25) 0%, transparent 75%); animation: aurora-flow-3 22s ease-in-out infinite; }
    .aurora-band-4 { width: 70%; height: 35%; top: 30%; left: 15%; background: radial-gradient(ellipse at 40% 50%, rgba(15,106,123,0.2) 0%, transparent 70%); animation: aurora-flow-4 18s ease-in-out infinite; }

    @keyframes aurora-flow-1 { 0%, 100% { transform: translate(0,0) scale(1); } 50% { transform: translate(5%, 2%) scale(1.05); } }
    @keyframes aurora-flow-2 { 0%, 100% { transform: translate(0,0) scale(1); } 50% { transform: translate(-3%, -4%) scale(1.1); } }
    @keyframes aurora-flow-3 { 0%, 100% { transform: translate(0,0) scale(1); } 50% { transform: translate(2%, 5%) scale(1.08); } }
    @keyframes aurora-flow-4 { 0%, 100% { transform: translate(0,0) scale(1); } 50% { transform: translate(-4%, 3%) scale(1.06); } }

    /* ── Shell Adjustments ── */
    .docs-shell { padding-top: 0 !important; max-width: 1200px !important; }
    .docs-sidebar { background: transparent !important; border-right: none !important; top: 100px !important; }
    .docs-main { padding: 0 64px 100px !important; }

    /* Reveal Animation Support */
    .reveal {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.65s cubic-bezier(0.16, 1, 0.3, 1), transform 0.65s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .reveal.visible { opacity: 1; transform: translateY(0); }
    .reveal-delay-1 { transition-delay: 0.08s; }
  </style>
{% endblock %}


{% block content %}

  <canvas id="bg-canvas"></canvas>

  <nav class="docs-nav" id="navbar">
    <a class="nav-logo" href="index" aria-label="Mesh Startseite"><img src="/assets/brand/lockup-color.svg" alt="Mesh"/></a>
    <div class="nav-divider"></div>
    <div class="nav-links">
      <a href="index">Start</a>
      <a href="how-it-works">So funktioniert es</a>
      <a href="statistics">Statistiken</a>
      <a class="active" href="docs">Dokumentation</a>
      <a href="terminal">Terminal</a>
    </div>
    <div class="nav-actions">
      <a class="nav-btn-primary" href="app?login=1">Workspace</a>
    </div>
  </nav>

  <main>
    <header class="hero reveal" id="ueberblick">
      <div class="hero-aurora">
        <div class="aurora-band aurora-band-1"></div>
        <div class="aurora-band aurora-band-2"></div>
        <div class="aurora-band aurora-band-3"></div>
        <div class="aurora-band aurora-band-4"></div>
      </div>
      <div class="eyebrow">Mesh Produktdokumentation</div>
      <h1>Infrastruktur für Engineering-Teams</h1>
      <p>Verbindet Produktverständnis, Architektur und Betriebsleitfäden in einer klaren Struktur. Für Teams, die Mesh sicher skalieren wollen.</p>
    </header>

    <div class="docs-shell">
      <aside class="docs-sidebar">
        <div class="side-title">Navigation</div>
        <nav class="side-nav">
          <a class="active" href="#ueberblick">Überblick</a>
          <a href="#architektur">Architekturfluss</a>
          <a href="#api">API und SDK</a>
          <a href="#betrieb">Betrieb</a>
          <a href="#sicherheit">Sicherheit</a>
        </nav>
      </aside>

      <div class="docs-main">
        <div class="section">
          <p class="section-label reveal">Kernbegriffe</p>
          <h2 class="section-title reveal reveal-delay-1">Die drei Säulen der Mesh-Interaktion</h2>
          <div class="grid-cards">
            <div class="card reveal reveal-delay-1">
              <div class="icon-pill">C</div>
              <h3>Capsule</h3>
              <p>Die strukturierte Zusammenfassung einer Datei. Reduziert Rauschen, erhält aber die logische Verbindung zum Original.</p>
            </div>
            <div class="card reveal reveal-delay-2">
              <div class="icon-pill">F</div>
              <h3>Focused</h3>
              <p>Mesh zeigt nur die Stellen, die exakt zu deiner Frage passen. Retrieval auf höchstem Präzisionsniveau.</p>
            </div>
            <div class="card reveal reveal-delay-1">
              <div class="icon-pill">R</div>
              <h3>Recovery</h3>
              <p>Lädt bei Bedarf die exakten Originalzeilen nach, um Beweise für jede Antwort zu liefern.</p>
            </div>
          </div>
        </div>

        <div class="section" id="architektur">
          <p class="section-label reveal">Pipeline</p>
          <h2 class="section-title reveal reveal-delay-1">Architekturfluss von Ingest bis Antwort</h2>
          <div class="timeline reveal reveal-delay-1">
            <div class="step">
              <div class="step-n">01</div>
              <div class="step-t">Workspace-Ingest erzeugt Manifest und setzt Dateien auf <code>pending</code>.</div>
            </div>
            <div class="step">
              <div class="step-n">02</div>
              <div class="step-t">Worker Tunnel (node-worker) erstellt strukturierte Capsules mit AST-Parsern.</div>
            </div>
            <div class="step">
              <div class="step-n">03</div>
              <div class="step-t">Focused Retrieval reduziert den Kontext auf query-relevante Ausschnitte.</div>
            </div>
            <div class="step">
              <div class="step-n">04</div>
              <div class="step-t">Recovery lädt exakte Evidenz (Span-IDs) via S3 nach.</div>
            </div>
          </div>
        </div>

        <div class="section" id="api">
          <p class="section-label reveal">Schnittstellen</p>
          <h2 class="section-title reveal reveal-delay-1">API-Referenz im Überblick</h2>
          <div class="matrix reveal reveal-delay-1">
            <div class="matrix-row head">
              <div>Endpunkt</div><div>Nutzen</div><div>Ergebnis</div>
            </div>
            <div class="matrix-row">
              <div>GET /workspace/files</div><div>Gesundheit und Status</div><div>Dateiliste + Status</div>
            </div>
            <div class="matrix-row">
              <div>GET /workspace/file</div><div>Spezifische Ansicht</div><div>original / focused / capsule</div>
            </div>
            <div class="matrix-row">
              <div>POST /chat</div><div>Kontext-Antwort</div><div>Response + Belege</div>
            </div>
          </div>
        </div>

        <div class="code-wrap reveal">
          <div class="code-header">
            <span>Dateivertrag (File Record)</span>
            <button class="code-copy" onclick="navigator.clipboard.writeText(this.closest('.code-wrap').querySelector('pre').textContent)">Copy JSON</button>
          </div>
          <pre class="code-pre">{
  "path": "src/routes/assistant-workspace.routes.js",
  "status": "completed",
  "views": {
    "original": "...",
    "capsule": "...",
    "focused": { "queryHash": "...", "content": "..." }
  },
  "recovery": {
    "spanMap": [{ "spanId": "auth:142", "lineStart": 142 }]
  }
}</pre>
        </div>

        <div class="section" id="betrieb">
          <p class="section-label reveal">Operationen</p>
          <h2 class="section-title reveal reveal-delay-1">Runbooks für den stabilen Betrieb</h2>
          <div class="grid-cards">
            <div class="card reveal reveal-delay-1">
              <h3>Queue-Health</h3>
              <p>Wenn pending Dateien steigen: Prüfen der Event-Kette und Queue-Latenz in der Worker-Instanz.</p>
            </div>
            <div class="card reveal reveal-delay-2">
              <h3>Fehlerklassen</h3>
              <p>Wenn failed Dateien steigen: Gruppieren der Error-Logs und Durchführung eines selektiven Retrys.</p>
            </div>
            <div class="card reveal reveal-delay-1">
              <h3>Genauigkeit</h3>
              <p>Wenn Antworten unpräzise sind: Validierung des Focused-Scoring und der Recovery-Span Definitionen.</p>
            </div>
          </div>
        </div>

        <div class="section" id="sicherheit">
          <p class="section-label reveal">Compliance</p>
          <h2 class="section-title reveal reveal-delay-1">Sicherheit und Audit-Fähigkeit</h2>
          <div class="matrix reveal reveal-delay-1">
            <div class="matrix-row head">
              <div>Domäne</div><div>Ansatz</div><div>Vorteil</div>
            </div>
            <div class="matrix-row">
              <div>Integrität</div><div>Digest-Ketten</div><div>Manipulationsschutz</div>
            </div>
            <div class="matrix-row">
              <div>Isolation</div><div>AWS S3 IAM Tags</div><div>Kein Datenleck</div>
            </div>
          </div>
        </div>

      </div> <!-- end docs-main -->
    </div> <!-- end docs-shell -->
  </main>

  <footer>
    <div class="footer-inner">
      <div class="footer-logo"><img src="/assets/brand/wordmark-black.svg" alt="Mesh"/></div>
      <div class="footer-links">
        <a href="docs">Dokumentation</a>
        <a href="how-it-works">So funktioniert es</a>
        <a href="statistics">Statistiken</a>
        <a href="app">Arbeitsbereich</a>
      </div>
      <p class="footer-copy">2026 Mesh. Kontext-Infrastruktur für Engineering-Teams.</p>
    </div>
  </footer>

  <script>
    (function initBackground() {
      const canvas = document.getElementById("bg-canvas");
      const ctx = canvas.getContext("2d");
      let width = 0, height = 0;
      const CELL = 42, WAVE_SPEED = 0.0006, WAVE_AMP = 6, WAVE_LEN = 280;
      const LINE_COLOR = "rgba(15,106,123,", DOT_COLOR = "rgba(95,149,168,";
      const BASE_LINE_ALPHA = 0.055, BASE_DOT_ALPHA = 0.12, DOT_R = 1.2;
      let cols = 0, rows = 0, offsetX = 0, offsetY = 0, mouseX = -1, mouseY = -1;
      const MOUSE_RADIUS = 180, MOUSE_STRENGTH = 14;

      function resize() {
        width = canvas.width = window.innerWidth;
        height = canvas.height = window.innerHeight;
        cols = Math.ceil(width / CELL) + 2;
        rows = Math.ceil(height / CELL) + 2;
        offsetX = (width - (cols - 1) * CELL) * 0.5;
        offsetY = (height - (rows - 1) * CELL) * 0.5;
      }
      resize();

      document.addEventListener("mousemove", function(e) { mouseX = e.clientX; mouseY = e.clientY; }, { passive: true });
      document.addEventListener("mouseleave", function() { mouseX = -1; mouseY = -1; });

      function getDisplacement(baseX, baseY, time) {
        var dx = Math.sin((baseX + baseY) / WAVE_LEN + time) * WAVE_AMP;
        var dy = Math.cos((baseX - baseY * 0.7) / WAVE_LEN + time * 1.3) * WAVE_AMP;
        if (mouseX >= 0) {
          var mx = baseX + dx - mouseX, my = baseY + dy - mouseY;
          var dist = Math.sqrt(mx * mx + my * my);
          if (dist < MOUSE_RADIUS && dist > 0) {
            var push = (1 - dist / MOUSE_RADIUS) * MOUSE_STRENGTH;
            dx += (mx / dist) * push; dy += (my / dist) * push;
          }
        }
        return { x: baseX + dx, y: baseY + dy };
      }

      function frame(now) {
        ctx.clearRect(0, 0, width, height);
        var t = now * WAVE_SPEED;
        ctx.lineWidth = 0.5;
        for (var r = 0; r < rows; r++) {
          for (var c = 0; c < cols; c++) {
            var bx = offsetX + c * CELL, by = offsetY + r * CELL;
            var p = getDisplacement(bx, by, t);
            if (c < cols - 1) {
              var np = getDisplacement(offsetX + (c + 1) * CELL, by, t);
              ctx.beginPath(); ctx.moveTo(p.x, p.y); ctx.lineTo(np.x, np.y);
              ctx.strokeStyle = LINE_COLOR + BASE_LINE_ALPHA + ")"; ctx.stroke();
            }
            if (r < rows - 1) {
              var np2 = getDisplacement(bx, offsetY + (r + 1) * CELL, t);
              ctx.beginPath(); ctx.moveTo(p.x, p.y); ctx.lineTo(np2.x, np2.y);
              ctx.strokeStyle = LINE_COLOR + BASE_LINE_ALPHA + ")"; ctx.stroke();
            }
            ctx.beginPath(); ctx.arc(p.x, p.y, DOT_R, 0, Math.PI * 2);
            ctx.fillStyle = DOT_COLOR + BASE_DOT_ALPHA + ")"; ctx.fill();
          }
        }
        requestAnimationFrame(frame);
      }
      window.addEventListener("resize", resize);
      requestAnimationFrame(frame);
    })();

    (function() {
      var nav = document.getElementById("navbar");
      function update() { nav.classList.toggle("scrolled", window.scrollY > 20); }
      window.addEventListener("scroll", update, { passive: true });

      // Sidebar active link on scroll
      var sections = document.querySelectorAll("div.section[id]");
      var sideLinks = document.querySelectorAll(".side-nav a");
      window.addEventListener("scroll", function() {
        var scrollY = window.scrollY + 120;
        sections.forEach(function(sec) {
          if (sec.offsetTop <= scrollY && (sec.offsetTop + sec.offsetHeight) > scrollY) {
            sideLinks.forEach(function(a) {
              a.classList.toggle("active", a.getAttribute("href") === "#" + sec.id);
            });
          }
        });
      }, { passive: true });
    })();

    (function() {
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) { entry.target.classList.add("visible"); observer.unobserve(entry.target); }
        });
      }, { threshold: 0.1 });
      document.querySelectorAll(".reveal").forEach(function(el) { observer.observe(el); });
    })();
  </script>

{% endblock %}
