{% extends "layouts/base.njk" %}

{% block title %}Documentation - Mesh{% endblock %}

{% block head %}
<link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Berkeley+Mono&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <script>
    (function() {
      var p = window.location.pathname;
      if (p.endsWith('.html')) {
        history.replaceState(null, '', p.replace(/\.html$/, '') + window.location.search + window.location.hash);
      }
    })();
  </script>
  <style>
    :root {
      --primary: #0f6a7b;
      --primary-deep: #123f5c;
      --secondary: #5f95a8;
      --tertiary: #1f496b;
      --surface: #f7fbfd;
      --surface-low: #ffffff;
      --surface-mid: #eef5f8;
      --ink: #102432;
      --ink-soft: #607787;
      --outline: #9bb0bc;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    body {
      background: var(--surface);
      color: var(--ink);
      font-family: "Inter", sans-serif;
      overflow-x: hidden;
    }

    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 450, 'GRAD' 0, 'opsz' 24;
      vertical-align: middle;
    }

    #bg-canvas { position: fixed; inset: 0; z-index: 0; pointer-events: none; }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      z-index: 1;
      pointer-events: none;
      opacity: 0.02;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    }

    /* ── Nav ── */
    .docs-nav {
      position: fixed;
      top: 16px;
      left: 50%;
      transform: translateX(-50%);
      right: auto;
      width: auto;
      max-width: 720px;
      height: auto;
      padding: 8px 8px 8px 20px;
      background: rgba(255, 255, 255, 0.06);
      backdrop-filter: blur(20px) saturate(150%);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 999px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.25);
      z-index: 100;
      display: flex;
      align-items: center;
      gap: 4px;
      transition: background 0.4s ease, border-color 0.4s ease, box-shadow 0.4s ease;
    }

    .nav-logo img { height: 20px; filter: brightness(0) invert(1); transition: filter 0.4s ease; }
    .nav-divider { width: 1px; height: 16px; background: rgba(255,255,255,0.2); margin: 0 6px; }
    .nav-links { display: flex; gap: 2px; }
    .nav-links a { font-size: 0.76rem; font-weight: 500; color: rgba(255, 255, 255, 0.6); padding: 6px 12px; border-radius: 999px; text-decoration: none; transition: 0.2s; }
    .nav-links a:hover { color: rgba(255, 255, 255, 0.95); background: rgba(255, 255, 255, 0.08); }
    .nav-links a.active { color: #fff; background: rgba(255, 255, 255, 0.1); }
    .nav-actions { display: flex; align-items: center; gap: 6px; margin-left: 4px; }
    .nav-btn-ghost { display: none; }
    .nav-btn-primary { font-size: 0.76rem; font-weight: 600; color: #fff; padding: 7px 16px; border-radius: 999px; background: rgba(15, 106, 123, 0.5); text-decoration: none; backdrop-filter: blur(10px); transition: background 0.2s; }
    .nav-btn-primary:hover { background: rgba(15, 106, 123, 0.7); }

    .docs-nav.scrolled {
      background: rgba(255, 255, 255, 0.82);
      backdrop-filter: blur(20px) saturate(180%);
      border-color: rgba(0, 0, 0, 0.06);
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    }
    .docs-nav.scrolled .nav-logo img { filter: none; }
    .docs-nav.scrolled .nav-links a { color: rgba(16, 36, 50, 0.55); }
    .docs-nav.scrolled .nav-links a:hover { color: #102432; background: rgba(15, 106, 123, 0.06); }
    .docs-nav.scrolled .nav-links a.active { color: #0f6a7b; background: rgba(15, 106, 123, 0.08); }
    .docs-nav.scrolled .nav-divider { background: rgba(0, 0, 0, 0.1) !important; }
    .docs-nav.scrolled .nav-btn-primary { background: linear-gradient(135deg, #0f6a7b, #123f5c); }

    /* ── Page shell ── */
    main { position: relative; z-index: 2; padding-top: 0; }
    .page-inner { max-width: 900px; margin: 0 auto; padding: 0 24px 100px; }
    a { color: inherit; text-decoration: none; }

    /* ── Hero ── */
    .hero {
      padding: 160px 24px 100px;
      margin-bottom: 64px;
      background: linear-gradient(180deg, #070e14 0%, #0d1f2d 50%, #1a3a4a 75%, #f7fbfd 100%);
      position: relative;
      overflow: hidden;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .hero::after {
      content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 25%;
      background: linear-gradient(180deg, transparent, var(--surface)); z-index: 3; pointer-events: none;
    }

    .hero-aurora { position: absolute; inset: -40% -20%; pointer-events: none; filter: blur(70px); opacity: 0.6; z-index: 0; }
    .aurora-band { position: absolute; border-radius: 50%; }
    .aurora-band-1 { width: 120%; height: 45%; top: -10%; left: -10%; background: radial-gradient(ellipse at 30% 50%, rgba(15,106,123,0.35) 0%, rgba(15,106,123,0.08) 40%, transparent 70%); animation: aurora-flow-1 16s ease-in-out infinite; }
    .aurora-band-2 { width: 90%; height: 50%; top: 20%; right: -15%; background: radial-gradient(ellipse at 70% 40%, rgba(31,73,107,0.3) 0%, rgba(95,149,168,0.1) 45%, transparent 70%); animation: aurora-flow-2 20s ease-in-out infinite; }
    .aurora-band-3 { width: 100%; height: 55%; bottom: -15%; left: 5%; background: radial-gradient(ellipse at 50% 60%, rgba(95,149,168,0.25) 0%, rgba(15,106,123,0.06) 50%, transparent 75%); animation: aurora-flow-3 22s ease-in-out infinite; }
    .aurora-band-4 { width: 70%; height: 35%; top: 30%; left: 15%; background: radial-gradient(ellipse at 40% 50%, rgba(15,106,123,0.2) 0%, rgba(31,73,107,0.08) 50%, transparent 70%); animation: aurora-flow-4 18s ease-in-out infinite; }

    @keyframes aurora-flow-1 { 0%, 100% { transform: translate(0,0) scale(1) rotate(0deg); } 33% { transform: translate(8%,5%) scale(1.12) rotate(2deg); } 66% { transform: translate(-5%,-3%) scale(0.95) rotate(-1deg); } }
    @keyframes aurora-flow-2 { 0%, 100% { transform: translate(0,0) scale(1) rotate(0deg); } 25% { transform: translate(-10%,6%) scale(1.08) rotate(-2deg); } 50% { transform: translate(5%,-4%) scale(0.92) rotate(1deg); } 75% { transform: translate(-3%,8%) scale(1.05) rotate(-1deg); } }
    @keyframes aurora-flow-3 { 0%, 100% { transform: translate(0,0) scale(1) rotate(0deg); } 30% { transform: translate(6%,-5%) scale(1.1) rotate(1.5deg); } 60% { transform: translate(-8%,3%) scale(0.93) rotate(-2deg); } }
    @keyframes aurora-flow-4 { 0%, 100% { transform: translate(0,0) scale(1); opacity: 0.6; } 50% { transform: translate(12%,-8%) scale(1.15); opacity: 1; } }

    .hero .eyebrow {
      font-family: "Berkeley Mono", monospace; font-size: 0.62rem;
      letter-spacing: 0.18em; text-transform: uppercase; color: #72a9bf;
      margin-bottom: 16px; position: relative; z-index: 4;
    }
    .hero h1 {
      font-size: clamp(2.5rem, 5vw, 3.8rem); font-weight: 800;
      letter-spacing: -0.04em; line-height: 1.05; color: #fff;
      margin-bottom: 18px; position: relative; z-index: 4;
    }
    .hero p {
      font-size: 1.05rem; color: rgba(255,255,255,0.6); line-height: 1.7;
      max-width: 640px; position: relative; z-index: 4;
    }

    /* ── Section ── */
    .section { margin-bottom: 64px; }
    .section-label {
      font-family: "Berkeley Mono", monospace; font-size: 0.6rem;
      letter-spacing: 0.18em; text-transform: uppercase; color: var(--outline); margin-bottom: 10px;
    }
    .section-title {
      font-size: clamp(1.4rem, 2.5vw, 1.9rem); font-weight: 700;
      letter-spacing: -0.03em; color: var(--ink); margin-bottom: 32px; line-height: 1.2;
    }

    /* ── Cards ── */
    .grid-cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 16px; }
    .card {
      background: var(--surface-low); border: 1px solid rgba(18,62,89,0.1);
      border-radius: 18px; padding: 24px;
      box-shadow: 0 4px 20px rgba(17,52,74,0.05);
      transition: box-shadow 0.2s ease, transform 0.2s ease;
    }
    .card:hover { box-shadow: 0 8px 32px rgba(17,52,74,0.1); transform: translateY(-2px); }
    .icon-pill {
      display: inline-flex; align-items: center; justify-content: center;
      width: 36px; height: 36px; border-radius: 10px;
      background: rgba(15,106,123,0.08); color: var(--primary);
      font-family: "Berkeley Mono", monospace; font-size: 0.75rem; font-weight: 700; margin-bottom: 14px;
    }
    .card h3 { font-size: 0.95rem; font-weight: 700; letter-spacing: -0.02em; color: var(--ink); margin-bottom: 8px; }
    .card p { font-size: 0.84rem; color: var(--ink-soft); line-height: 1.65; }
    .card code { font-family: "Berkeley Mono", monospace; font-size: 0.78em; background: rgba(15,106,123,0.08); color: var(--primary); padding: 2px 6px; border-radius: 4px; }

    /* ── Timeline ── */
    .timeline { display: flex; flex-direction: column; gap: 0; }
    .step { display: flex; gap: 20px; padding: 20px 0; border-bottom: 1px solid rgba(18,62,89,0.08); }
    .step:last-child { border-bottom: none; }
    .step-n {
      flex-shrink: 0; width: 36px; height: 36px; border-radius: 50%;
      background: rgba(15,106,123,0.08); border: 1.5px solid rgba(15,106,123,0.2);
      display: flex; align-items: center; justify-content: center;
      font-family: "Berkeley Mono", monospace; font-size: 0.72rem; font-weight: 700; color: var(--primary); margin-top: 2px;
    }
    .step-t { font-size: 0.92rem; color: var(--ink-soft); line-height: 1.7; padding-top: 6px; }
    .step-t code { font-family: "Berkeley Mono", monospace; font-size: 0.82em; background: rgba(15,106,123,0.08); color: var(--primary); padding: 2px 6px; border-radius: 4px; }

    /* ── Matrix table ── */
    .matrix { border: 1px solid rgba(18,62,89,0.1); border-radius: 16px; overflow: hidden; background: var(--surface-low); }
    .matrix-row { display: grid; grid-template-columns: 1fr 1fr 1fr; padding: 14px 20px; border-bottom: 1px solid rgba(18,62,89,0.08); gap: 12px; }
    .matrix-row:last-child { border-bottom: none; }
    .matrix-row.head { background: rgba(15,106,123,0.04); font-family: "Berkeley Mono", monospace; font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--outline); }
    .matrix-row div { font-size: 0.87rem; color: var(--ink-soft); line-height: 1.5; }

    /* ── Code block ── */
    .code-wrap { background: #0d1f2d; border-radius: 16px; overflow: hidden; margin-bottom: 64px; }
    .code-header { display: flex; align-items: center; justify-content: space-between; padding: 12px 20px; border-bottom: 1px solid rgba(255,255,255,0.06); }
    .code-header span { font-family: "Berkeley Mono", monospace; font-size: 0.68rem; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(255,255,255,0.35); }
    .code-copy { appearance: none; background: transparent; border: 1px solid rgba(255,255,255,0.1); color: #fff; font-size: 0.7rem; padding: 4px 10px; border-radius: 6px; cursor: pointer; }
    .code-copy:hover { background: rgba(255,255,255,0.05); }
    .code-pre { padding: 24px 20px; font-family: "Berkeley Mono", monospace; font-size: 0.82rem; line-height: 1.8; color: #a8d8e8; white-space: pre; overflow-x: auto; }

    /* ── Footer ── */
    footer { position: relative; z-index: 2; border-top: 1px solid rgba(18,62,89,0.12); padding: 36px 28px; }
    .footer-inner { max-width: 900px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; gap: 20px; flex-wrap: wrap; }
    .footer-logo img { height: 16px; }
    .footer-links { display: flex; gap: 4px; flex-wrap: wrap; }
    .footer-links a { text-decoration: none; font-family: "Berkeley Mono", monospace; font-size: 0.62rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--outline); padding: 5px 10px; border-radius: 6px; transition: color 0.2s, background 0.2s; }
    .footer-links a:hover { color: var(--ink-soft); background: rgba(15,106,123,0.05); }
    .footer-copy { font-family: "Berkeley Mono", monospace; font-size: 0.58rem; letter-spacing: 0.08em; text-transform: uppercase; color: #91a6b3; }

    /* ── Sidebar (docs-specific) ── */
    .docs-shell { display: grid; grid-template-columns: 220px 1fr; max-width: 1200px; margin: 0 auto; }
    .docs-sidebar { position: sticky; top: 100px; height: fit-content; padding: 0 20px; }
    .side-title { font-family: "Berkeley Mono", monospace; font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.16em; color: var(--outline); opacity: 0.6; margin-bottom: 12px; }
    .side-nav { display: flex; flex-direction: column; gap: 2px; }
    .side-nav a { padding: 8px 14px; border-radius: 10px; font-size: 0.84rem; font-weight: 500; color: var(--ink-soft); text-decoration: none; transition: background 0.2s, color 0.2s; }
    .side-nav a:hover { background: rgba(15,106,123,0.05); color: var(--ink); }
    .side-nav a.active { background: rgba(15,106,123,0.08); color: var(--primary); font-weight: 600; }
    .docs-main { padding: 0 64px 100px; }

    /* ── Reveal ── */
    .reveal { opacity: 0; transform: translateY(20px); transition: opacity 0.65s cubic-bezier(0.16,1,0.3,1), transform 0.65s cubic-bezier(0.16,1,0.3,1); }
    .reveal.visible { opacity: 1; transform: translateY(0); }
    .reveal-delay-1 { transition-delay: 0.08s; }
    .reveal-delay-2 { transition-delay: 0.16s; }

    /* ── Responsive ── */
    @media (max-width: 900px) {
      .docs-shell { grid-template-columns: 1fr; }
      .docs-sidebar { display: none; }
      .docs-main { padding: 0 24px 100px; }
    }
    @media (max-width: 640px) {
      .nav-links { display: none; }
      .grid-cards { grid-template-columns: 1fr; }
      .matrix-row { grid-template-columns: 1fr; }
    }
    @media (prefers-reduced-motion: reduce) {
      * { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; }
    }
  </style>
{% endblock %}


{% block content %}

  <canvas id="bg-canvas"></canvas>

  {% set activePage = "docs" %}
  {% include "partials/site-nav.njk" %}

  <main>
    <header class="hero reveal" id="overview">
      <div class="hero-aurora">
        <div class="aurora-band aurora-band-1"></div>
        <div class="aurora-band aurora-band-2"></div>
        <div class="aurora-band aurora-band-3"></div>
        <div class="aurora-band aurora-band-4"></div>
      </div>
      <div class="eyebrow">Mesh Product Documentation</div>
      <h1>Infrastructure for engineering teams</h1>
      <p>Connects product understanding, architecture, and operational runbooks in one clear structure for teams that want to scale Mesh safely.</p>
    </header>

    <div class="docs-shell">
      <aside class="docs-sidebar">
        <div class="side-title">Navigation</div>
        <nav class="side-nav">
          <a class="active" href="#overview">Overview</a>
          <a href="#architecture-flow">Architecture Flow</a>
          <a href="#api">API and SDK</a>
          <a href="#operations">Operations</a>
          <a href="#security">Security</a>
        </nav>
      </aside>

      <div class="docs-main">
        <div class="section">
          <p class="section-label reveal">Core Concepts</p>
          <h2 class="section-title reveal reveal-delay-1">The three pillars of Mesh interaction</h2>
          <div class="grid-cards">
            <div class="card reveal reveal-delay-1">
              <div class="icon-pill">C</div>
              <h3>Capsule</h3>
              <p>The structured summary of a file. It reduces noise while preserving the logical link to the original.</p>
            </div>
            <div class="card reveal reveal-delay-2">
              <div class="icon-pill">F</div>
              <h3>Focused</h3>
              <p>Mesh shows only the passages that match your question exactly. Retrieval with maximum precision.</p>
            </div>
            <div class="card reveal reveal-delay-1">
              <div class="icon-pill">R</div>
              <h3>Recovery</h3>
              <p>Loads exact original lines on demand to provide proof for every answer.</p>
            </div>
          </div>
        </div>

        <div class="section" id="architecture-flow">
          <p class="section-label reveal">Pipeline</p>
          <h2 class="section-title reveal reveal-delay-1">Architecture flow from ingest to answer</h2>
          <div class="timeline reveal reveal-delay-1">
            <div class="step">
              <div class="step-n">01</div>
              <div class="step-t">Workspace ingest creates the manifest and sets files to <code>pending</code>.</div>
            </div>
            <div class="step">
              <div class="step-n">02</div>
              <div class="step-t">The worker tunnel (node-worker) creates structured capsules with AST parsers.</div>
            </div>
            <div class="step">
              <div class="step-n">03</div>
              <div class="step-t">Focused retrieval reduces context to query-relevant excerpts.</div>
            </div>
            <div class="step">
              <div class="step-n">04</div>
              <div class="step-t">Recovery retrieves exact evidence (span IDs) through S3.</div>
            </div>
          </div>
        </div>

        <div class="section" id="api">
          <p class="section-label reveal">Interfaces</p>
          <h2 class="section-title reveal reveal-delay-1">API reference overview</h2>
          <div class="matrix reveal reveal-delay-1">
            <div class="matrix-row head">
              <div>Endpoint</div><div>Use</div><div>Result</div>
            </div>
            <div class="matrix-row">
              <div>GET /workspace/files</div><div>Health and status</div><div>File list + status</div>
            </div>
            <div class="matrix-row">
              <div>GET /workspace/file</div><div>Specific view</div><div>original / focused / capsule</div>
            </div>
            <div class="matrix-row">
              <div>POST /chat</div><div>Context answer</div><div>Response + evidence</div>
            </div>
          </div>
        </div>

        <div class="code-wrap reveal">
          <div class="code-header">
            <span>File contract (File Record)</span>
            <button class="code-copy" onclick="navigator.clipboard.writeText(this.closest('.code-wrap').querySelector('pre').textContent)">Copy JSON</button>
          </div>
          <pre class="code-pre">{
  "path": "src/routes/assistant-workspace.routes.js",
  "status": "completed",
  "views": {
    "original": "...",
    "capsule": "...",
    "focused": { "queryHash": "...", "content": "..." }
  },
  "recovery": {
    "spanMap": [{ "spanId": "auth:142", "lineStart": 142 }]
  }
}</pre>
        </div>

        <div class="section" id="operations">
          <p class="section-label reveal">Operations</p>
          <h2 class="section-title reveal reveal-delay-1">Runbooks for stable operations</h2>
          <div class="grid-cards">
            <div class="card reveal reveal-delay-1">
              <h3>Queue Health</h3>
              <p>When pending files increase, inspect the event chain and queue latency in the worker instance.</p>
            </div>
            <div class="card reveal reveal-delay-2">
              <h3>Error Classes</h3>
              <p>When failed files increase, group the error logs and run a selective retry.</p>
            </div>
            <div class="card reveal reveal-delay-1">
              <h3>Accuracy</h3>
              <p>When answers are imprecise, validate focused scoring and recovery span definitions.</p>
            </div>
          </div>
        </div>

        <div class="section" id="security">
          <p class="section-label reveal">Compliance</p>
          <h2 class="section-title reveal reveal-delay-1">Security and auditability</h2>
          <div class="matrix reveal reveal-delay-1">
            <div class="matrix-row head">
              <div>Domain</div><div>Approach</div><div>Benefit</div>
            </div>
            <div class="matrix-row">
              <div>Integrity</div><div>Digest chains</div><div>Tamper protection</div>
            </div>
            <div class="matrix-row">
              <div>Isolation</div><div>AWS S3 IAM Tags</div><div>No data leakage</div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </main>

  {% include "partials/site-footer.njk" %}

  <script>
    (function initBackground() {
      const canvas = document.getElementById("bg-canvas");
      const ctx = canvas.getContext("2d");
      let width = 0, height = 0;
      const CELL = 42, WAVE_SPEED = 0.0006, WAVE_AMP = 6, WAVE_LEN = 280;
      const LINE_COLOR = "rgba(15,106,123,", DOT_COLOR = "rgba(95,149,168,";
      const BASE_LINE_ALPHA = 0.055, BASE_DOT_ALPHA = 0.12, DOT_R = 1.2;
      let cols = 0, rows = 0, offsetX = 0, offsetY = 0, mouseX = -1, mouseY = -1;
      const MOUSE_RADIUS = 180, MOUSE_STRENGTH = 14;

      function resize() {
        width = canvas.width = window.innerWidth;
        height = canvas.height = window.innerHeight;
        cols = Math.ceil(width / CELL) + 2;
        rows = Math.ceil(height / CELL) + 2;
        offsetX = (width - (cols - 1) * CELL) * 0.5;
        offsetY = (height - (rows - 1) * CELL) * 0.5;
      }
      resize();

      document.addEventListener("mousemove", function(e) { mouseX = e.clientX; mouseY = e.clientY; }, { passive: true });
      document.addEventListener("mouseleave", function() { mouseX = -1; mouseY = -1; });

      function getDisplacement(baseX, baseY, time) {
        var dx = Math.sin((baseX + baseY) / WAVE_LEN + time) * WAVE_AMP;
        var dy = Math.cos((baseX - baseY * 0.7) / WAVE_LEN + time * 1.3) * WAVE_AMP;
        if (mouseX >= 0) {
          var mx = baseX + dx - mouseX, my = baseY + dy - mouseY;
          var dist = Math.sqrt(mx * mx + my * my);
          if (dist < MOUSE_RADIUS && dist > 0) {
            var push = (1 - dist / MOUSE_RADIUS) * MOUSE_STRENGTH;
            dx += (mx / dist) * push; dy += (my / dist) * push;
          }
        }
        return { x: baseX + dx, y: baseY + dy };
      }

      function frame(now) {
        ctx.clearRect(0, 0, width, height);
        var t = now * WAVE_SPEED;
        ctx.lineWidth = 0.5;
        for (var r = 0; r < rows; r++) {
          for (var c = 0; c < cols; c++) {
            var bx = offsetX + c * CELL, by = offsetY + r * CELL;
            var p = getDisplacement(bx, by, t);
            if (c < cols - 1) {
              var np = getDisplacement(offsetX + (c + 1) * CELL, by, t);
              ctx.beginPath(); ctx.moveTo(p.x, p.y); ctx.lineTo(np.x, np.y);
              ctx.strokeStyle = LINE_COLOR + BASE_LINE_ALPHA + ")"; ctx.stroke();
            }
            if (r < rows - 1) {
              var np2 = getDisplacement(bx, offsetY + (r + 1) * CELL, t);
              ctx.beginPath(); ctx.moveTo(p.x, p.y); ctx.lineTo(np2.x, np2.y);
              ctx.strokeStyle = LINE_COLOR + BASE_LINE_ALPHA + ")"; ctx.stroke();
            }
            ctx.beginPath(); ctx.arc(p.x, p.y, DOT_R, 0, Math.PI * 2);
            ctx.fillStyle = DOT_COLOR + BASE_DOT_ALPHA + ")"; ctx.fill();
          }
        }
        requestAnimationFrame(frame);
      }
      window.addEventListener("resize", resize);
      requestAnimationFrame(frame);
    })();

    (function() {
      var nav = document.getElementById("navbar");
      function update() { if (nav) nav.classList.toggle("scrolled", window.scrollY > 20); }
      window.addEventListener("scroll", update, { passive: true });

      var sections = document.querySelectorAll("div.section[id]");
      var sideLinks = document.querySelectorAll(".side-nav a");
      window.addEventListener("scroll", function() {
        var scrollY = window.scrollY + 120;
        sections.forEach(function(sec) {
          if (sec.offsetTop <= scrollY && (sec.offsetTop + sec.offsetHeight) > scrollY) {
            sideLinks.forEach(function(a) {
              a.classList.toggle("active", a.getAttribute("href") === "#" + sec.id);
            });
          }
        });
      }, { passive: true });
    })();

    (function() {
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) { entry.target.classList.add("visible"); observer.unobserve(entry.target); }
        });
      }, { threshold: 0.1 });
      document.querySelectorAll(".reveal").forEach(function(el) { observer.observe(el); });
    })();
  </script>

{% endblock %}
