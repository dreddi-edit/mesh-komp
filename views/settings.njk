{% extends "layouts/base.njk" %}

{% block title %}Settings | Mesh{% endblock %}

{% block head %}
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
  
  
  
  <script>
    (function() {
      var p = window.location.pathname;
      if (p.endsWith('/index.html')) {
        history.replaceState(null, '', p.replace('/index.html', '/') + window.location.search + window.location.hash);
      }
    })();
  </script>
  <!--
    Apply the saved theme before CSS renders to prevent a dark flash.
    The :root in mesh-settings.css defaults to dark; this script sets
    data-theme="light" immediately when the user has light mode saved.
  -->
  <script>(function(){try{var a=JSON.parse(localStorage.getItem('meshAppearance')||'{}');var t=String(a.theme||'light').trim();if(t==='system')t=window.matchMedia&&window.matchMedia('(prefers-color-scheme:dark)').matches?'dark':'light';document.documentElement.dataset.theme=t==='dark'?'dark':'light';}catch(e){document.documentElement.dataset.theme='light';}}());</script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Berkeley+Mono&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <link href="/assets/mesh-settings.css" rel="stylesheet"/>
{% endblock %}

{% block body_attrs %} data-settings-page="account"{% endblock %}
{% block content %}

  <div class="settings-shell">
    <header class="settings-topbar">
      <a class="topbar-logo" href="/app" aria-label="Mesh workspace">
        <img src="/assets/brand/lockup-color.svg" alt="Mesh"/>
      </a>
      <a class="topbar-back" href="/app">← Workspace</a>
    </header>

    <aside class="settings-sidebar">
      <div class="sidebar-top">
        <div class="workspace-badge">
          <div class="workspace-dot"></div>
          <span>mesh-core / production</span>
        </div>
        <nav class="settings-nav">
          <a data-settings-section="account" href="#account" class="active">
            <span class="material-symbols-outlined">person</span>
            <div>
              <strong>Account</strong>
              <small>Profile and workspace identity</small>
            </div>
          </a>
          <a data-settings-section="security" href="#security">
            <span class="material-symbols-outlined">shield</span>
            <div>
              <strong>Security</strong>
              <small>Sessions, 2FA and recovery posture</small>
            </div>
          </a>
          <a data-settings-section="billing" href="#billing">
            <span class="material-symbols-outlined">credit_card</span>
            <div>
              <strong>Billing</strong>
              <small>Plan, invoices and usage</small>
            </div>
          </a>
          <a data-settings-section="api-keys" href="#api-keys">
            <span class="material-symbols-outlined">key</span>
            <div>
              <strong>API Keys</strong>
              <small>Automation credentials</small>
            </div>
          </a>
          <a data-settings-section="appearance" href="#appearance">
            <span class="material-symbols-outlined">palette</span>
            <div>
              <strong>Appearance</strong>
              <small>Theme, density and motion</small>
            </div>
          </a>
          <a data-settings-section="ai" href="#ai">
            <span class="material-symbols-outlined">neurology</span>
            <div>
              <strong>AI &amp; Models</strong>
              <small>Provider keys and model defaults</small>
            </div>
          </a>
        </nav>
      </div>

      <!-- Sidebar info cards — one set per section, toggled by the router -->
      <div class="sidebar-info" data-settings-sidebar-info="account">
        <div class="info-card">
          <div class="info-label">Workspace identity</div>
          <strong>One profile, all surfaces</strong>
          <p>Your display name and avatar appear in the activity feed, approval queue and operator audit trail.</p>
        </div>
        <div class="info-card">
          <div class="info-label">Integrations</div>
          <strong>Connect carefully</strong>
          <p>Third-party integrations inherit the operator's permission scope. Only connect services you actively use.</p>
        </div>
      </div>

      <div class="sidebar-info" data-settings-sidebar-info="security" hidden>
        <div class="info-card">
          <div class="info-label">Posture tip</div>
          <strong>Rotate after incidents</strong>
          <p>Any session used during a hotfix or emergency override should be expired immediately after the window closes.</p>
        </div>
        <div class="info-card">
          <div class="info-label">Recovery</div>
          <strong>Two recovery contacts</strong>
          <p>Keep at least two breakglass owners on record so a single point of failure never locks the workspace.</p>
        </div>
      </div>

      <div class="sidebar-info" data-settings-sidebar-info="billing" hidden>
        <div class="info-card">
          <div class="info-label">Annual savings</div>
          <strong>2 months free</strong>
          <p>Switch to annual billing and save the equivalent of two months compared to the monthly rate.</p>
        </div>
        <div class="info-card">
          <div class="info-label">Usage</div>
          <strong>Predictable at scale</strong>
          <p>Edge events and session counts are metered separately so costs reflect actual production load, not seat counts.</p>
        </div>
      </div>

      <div class="sidebar-info" data-settings-sidebar-info="api-keys" hidden>
        <div class="info-card">
          <div class="info-label">Best practice</div>
          <strong>One key per workflow</strong>
          <p>Separate deploy automation, read-only observability and local testing so revocation can stay surgical.</p>
        </div>
        <div class="info-card">
          <div class="info-label">Rotation</div>
          <strong>After every incident</strong>
          <p>Any key involved in a hotfix or emergency bypass should be rotated after the event closes.</p>
        </div>
      </div>

      <div class="sidebar-info" data-settings-sidebar-info="appearance" hidden>
        <div class="info-card">
          <div class="info-label">Ergonomics</div>
          <strong>Density for operators</strong>
          <p>Compact density reduces scroll depth during incident response. Comfortable density is better for long review sessions.</p>
        </div>
        <div class="info-card">
          <div class="info-label">Motion</div>
          <strong>Respect system settings</strong>
          <p>Reduced motion respects the OS-level preference automatically — no need to override it here unless you want to force a specific mode.</p>
        </div>
      </div>

      <div class="sidebar-info" data-settings-sidebar-info="ai" hidden>
        <div class="info-card">
          <div class="info-label">Key storage</div>
          <strong>Encrypted server store</strong>
          <p>API keys are stored per user in Mesh's encrypted database and loaded only for authenticated sessions.</p>
        </div>
        <div class="info-card">
          <div class="info-label">BYOK</div>
          <strong>Import extra models</strong>
          <p>Add your own compatible provider key in this page. Verified models are marked in the app dropdown, and new models are added under BYOK.</p>
        </div>
      </div>
    </aside>

    <main class="settings-content">

      <!-- ══════════════════════════════════════════════════════
           ACCOUNT
           ══════════════════════════════════════════════════════ -->
      <section data-settings-section="account">
        <div class="content-header">
          <div class="content-label">Operator identity</div>
          <h1 class="content-title">Account</h1>
          <p class="content-desc">Your profile, workspace membership and the integrations that extend your operator surface.</p>
        </div>

        <div class="stats-row">
          <article class="stat-card">
            <div class="stat-label"><span class="info-tip">Role<i class="info-tip-icon">i</i><span class="info-tip-bubble">Your permission level in this workspace. Owner has full access including billing and team management.</span></span></div>
            <div class="stat-value">Owner</div>
            <div class="stat-desc">Full workspace access with billing and operator management rights.</div>
          </article>
          <article class="stat-card">
            <div class="stat-label">Member since</div>
            <div class="stat-value">Jan 2025</div>
            <div class="stat-desc">Account age in this workspace. Role history is in the audit log.</div>
          </article>
          <article class="stat-card">
            <div class="stat-label"><span class="info-tip">Integrations<i class="info-tip-icon">i</i><span class="info-tip-bubble">Third-party services connected to your operator profile. Each inherits your current permission scope.</span></span></div>
            <div class="stat-value" data-account-stat="integrations">2</div>
            <div class="stat-desc" data-account-stat-desc="integrations">Third-party services connected to this operator profile.</div>
          </article>
        </div>

        <article class="settings-panel">
          <div class="panel-header">
            <div class="panel-kicker">Profile</div>
            <h2 class="panel-title">Operator profile</h2>
            <p class="panel-desc">Your display name and contact details appear throughout the workspace wherever operator identity is shown.</p>
          </div>
          <form class="panel-form" data-storage-key="meshAccountProfile">
            <div class="form-grid">
              <div class="field-group">
                <label class="field-label" for="acc-name">Display name</label>
                <input class="field-input" id="acc-name" name="displayName" type="text" placeholder="Your name"/>
              </div>
              <div class="field-group">
                <label class="field-label" for="acc-email">Email address</label>
                <input class="field-input" id="acc-email" name="email" type="email" placeholder="you@yourorg.com"/>
              </div>
              <div class="field-group">
                <label class="field-label" for="acc-handle">Operator handle</label>
                <input class="field-input" id="acc-handle" name="handle" type="text" placeholder="@handle"/>
              </div>
              <div class="field-group">
                <label class="field-label" for="acc-timezone">Timezone</label>
                <select class="field-select" id="acc-timezone" name="timezone">
                  <option value="UTC">UTC</option>
                  <option value="Europe/Berlin">Europe / Berlin</option>
                  <option value="America/New_York">America / New York</option>
                  <option value="America/Los_Angeles">America / Los Angeles</option>
                  <option value="Asia/Tokyo">Asia / Tokyo</option>
                  <option value="Asia/Singapore">Asia / Singapore</option>
                </select>
              </div>
            </div>
            <div class="panel-actions">
              <button class="btn-primary" type="submit">Save profile</button>
            </div>
          </form>
        </article>

        <article class="settings-panel">
          <div class="panel-header">
            <div class="panel-kicker">Workspace</div>
            <h2 class="panel-title">Workspace settings</h2>
            <p class="panel-desc">Workspace-level identity and configuration that applies to all operators in this environment.</p>
          </div>
          <form class="panel-form" data-storage-key="meshWorkspaceConfig">
            <div class="form-grid">
              <div class="field-group">
                <label class="field-label" for="ws-name">Workspace name</label>
                <input class="field-input" id="ws-name" name="workspaceName" type="text" placeholder="mesh-core"/>
              </div>
              <div class="field-group">
                <label class="field-label" for="ws-slug">Workspace slug</label>
                <input class="field-input" id="ws-slug" name="workspaceSlug" type="text" placeholder="mesh-core"/>
              </div>
              <div class="field-group">
                <label class="field-label" for="ws-region">Primary region</label>
                <select class="field-select" id="ws-region" name="primaryRegion">
                  <option value="EU Central">EU Central</option>
                  <option value="US East">US East</option>
                  <option value="US West">US West</option>
                  <option value="AP Southeast">AP Southeast</option>
                </select>
              </div>
              <div class="field-group">
                <label class="field-label" for="ws-env">Default environment</label>
                <select class="field-select" id="ws-env" name="defaultEnvironment">
                  <option value="production">Production</option>
                  <option value="staging">Staging</option>
                  <option value="observability">Observability</option>
                </select>
              </div>
              <div class="field-group span-2">
                <label class="field-label" for="ws-desc">Workspace description</label>
                <textarea class="field-textarea" id="ws-desc" name="description" rows="2" placeholder="Short description of this workspace's purpose and scope."></textarea>
              </div>
            </div>
            <div class="panel-actions">
              <button class="btn-primary" type="submit">Save workspace</button>
            </div>
          </form>
        </article>

        <article class="settings-panel">
          <div class="panel-header">
            <div class="panel-kicker">Integrations</div>
            <h2 class="panel-title">Connected services</h2>
            <p class="panel-desc">Third-party services connected to this operator profile. Each connection inherits your current permission scope.</p>
          </div>
          <div class="cards-list" data-integrations-list>
            <div class="session-card">
              <div class="session-meta" style="flex:1;">
                <strong>Loading integrations...</strong>
                <span class="badge badge-neutral">Syncing</span>
              </div>
              <div class="session-detail">Connected services will appear here once your operator profile loads.</div>
            </div>
          </div>
        </article>

        <article class="settings-panel">
          <div class="panel-header">
            <div class="panel-kicker">Notifications</div>
            <h2 class="panel-title">Notification routing</h2>
            <p class="panel-desc">Control which workspace events generate notifications and how they reach you.</p>
          </div>
          <div class="switches-list">
            <div class="switch-row">
              <div class="switch-info">
                <strong><span class="info-tip">Deploy approvals<i class="info-tip-icon">i</i><span class="info-tip-bubble">You'll get a notification whenever a deploy or policy change is queued and waiting for your sign-off.</span></span></strong>
                <span>Notify me when a deploy or policy change needs operator approval in this workspace.</span>
              </div>
              <label class="switch" data-switch="notifyDeploys">
                <input type="checkbox" checked/>
                <span class="switch-track"><span class="switch-thumb"></span></span>
              </label>
            </div>
            <div class="switch-row">
              <div class="switch-info">
                <strong><span class="info-tip">Route health alerts<i class="info-tip-icon">i</i><span class="info-tip-bubble">Triggered when any route score drops below 75 (warning) or enters a degraded state requiring action.</span></span></strong>
                <span>Receive alerts when a route score drops below the warning threshold or enters a degraded state.</span>
              </div>
              <label class="switch" data-switch="notifyRoutes">
                <input type="checkbox" checked/>
                <span class="switch-track"><span class="switch-thumb"></span></span>
              </label>
            </div>
            <div class="switch-row">
              <div class="switch-info">
                <strong><span class="info-tip">Security events<i class="info-tip-icon">i</i><span class="info-tip-bubble">Covers failed auth attempts, unusual session patterns, and any policy violations detected by the system.</span></span></strong>
                <span>Alert me when authentication anomalies or policy violations are detected in this workspace.</span>
              </div>
              <label class="switch" data-switch="notifySecurity">
                <input type="checkbox" checked/>
                <span class="switch-track"><span class="switch-thumb"></span></span>
              </label>
            </div>
            <div class="switch-row">
              <div class="switch-info">
                <strong><span class="info-tip">Billing and usage<i class="info-tip-icon">i</i><span class="info-tip-bubble">Alerts when your workspace approaches its quota limit or when an invoice is due in the next 7 days.</span></span></strong>
                <span>Notify me when usage approaches quota limits or invoice dates are approaching.</span>
              </div>
              <label class="switch" data-switch="notifyBilling">
                <input type="checkbox"/>
                <span class="switch-track"><span class="switch-thumb"></span></span>
              </label>
            </div>
          </div>
        </article>
      </section>

      <!-- ══════════════════════════════════════════════════════
           SECURITY
           ══════════════════════════════════════════════════════ -->
      <section data-settings-section="security" hidden>
        <div class="content-header">
          <div class="content-label">Trust posture</div>
          <h1 class="content-title">Security</h1>
          <p class="content-desc">Authentication baseline, active sessions and the audit trail that keeps every operator action traceable.</p>
        </div>

        <div class="stats-row">
          <article class="stat-card">
            <div class="stat-label"><span class="info-tip">2FA coverage<i class="info-tip-icon">i</i><span class="info-tip-bubble">Percentage of operators in this workspace with a second factor (TOTP or hardware key) enrolled.</span></span></div>
            <div class="stat-value">100%</div>
            <div class="stat-desc">All operators in this workspace have a second factor enrolled.</div>
          </article>
          <article class="stat-card">
            <div class="stat-label"><span class="info-tip">Review cadence<i class="info-tip-icon">i</i><span class="info-tip-bubble">How long before an operator session expires and re-authentication is required. Shorter = more secure.</span></span></div>
            <div class="stat-value" data-security-stat="ttl">14 d</div>
            <div class="stat-desc" data-security-stat-desc="ttl">Current session TTL before re-authentication is required.</div>
          </article>
          <article class="stat-card">
            <div class="stat-label"><span class="info-tip">Recovery contacts<i class="info-tip-icon">i</i><span class="info-tip-bubble">Breakglass owners can regain access to a locked workspace. Keep at least 2 registered.</span></span></div>
            <div class="stat-value" data-security-stat="recovery">2</div>
            <div class="stat-desc" data-security-stat-desc="recovery">Breakglass owners registered for emergency workspace access.</div>
          </article>
        </div>

        <article class="settings-panel">
          <div class="panel-header">
            <div class="panel-kicker">Baseline</div>
            <h2 class="panel-title">Authentication settings</h2>
            <p class="panel-desc">Define the policy layer that governs how operators authenticate and recover access to the workspace.</p>
          </div>
          <form class="panel-form" data-storage-key="meshSecurityBaseline">
            <div class="form-grid">
              <div class="field-group">
                <label class="field-label" for="sec-rotation"><span class="info-tip">Password rotation interval<i class="info-tip-icon">i</i><span class="info-tip-bubble">How often operators must update their password. 60 days is the recommended default.</span></span></label>
                <select class="field-select" id="sec-rotation" name="rotation">
                  <option value="30d">Every 30 days</option>
                  <option value="60d" selected>Every 60 days</option>
                  <option value="90d">Every 90 days</option>
                  <option value="never">Never (manual only)</option>
                </select>
              </div>
              <div class="field-group">
                <label class="field-label" for="sec-ttl"><span class="info-tip">Session TTL<i class="info-tip-icon">i</i><span class="info-tip-bubble">Time-to-live for an authenticated session. After this period, the operator must log in again.</span></span></label>
                <select class="field-select" id="sec-ttl" name="sessionTtl">
                  <option value="7d">7 days</option>
                  <option value="14d" selected>14 days</option>
                  <option value="30d">30 days</option>
                  <option value="90d">90 days</option>
                </select>
              </div>
              <div class="field-group">
                <label class="field-label" for="sec-recovery-email">Recovery email</label>
                <input class="field-input" id="sec-recovery-email" name="recoveryEmail" type="email" placeholder="security@yourorg.com"/>
              </div>
              <div class="field-group">
                <label class="field-label" for="sec-breakglass"><span class="info-tip">Breakglass owner<i class="info-tip-icon">i</i><span class="info-tip-bubble">An operator who can bypass normal auth to recover a locked workspace. Should be someone senior.</span></span></label>
                <input class="field-input" id="sec-breakglass" name="breakglass" type="text" placeholder="operator@yourorg.com"/>
              </div>
              <div class="field-group span-2">
                <label class="field-label" for="sec-notes">Recovery notes</label>
                <textarea class="field-textarea" id="sec-notes" name="recoveryNotes" rows="3" placeholder="Document the escalation path for locked workspaces and who holds recovery authority."></textarea>
              </div>
            </div>
            <div class="panel-actions">
              <button class="btn-primary" type="submit">Save baseline</button>
            </div>
          </form>
        </article>

        <article class="settings-panel">
          <div class="panel-header">
            <div class="panel-kicker">Protection</div>
            <h2 class="panel-title">Security controls</h2>
            <p class="panel-desc">Toggle the protection layer that governs how sessions, devices and alerts behave across the workspace.</p>
          </div>
          <div class="switches-list">
            <div class="switch-row">
              <div class="switch-info">
                <strong><span class="info-tip">Two-factor authentication<i class="info-tip-icon">i</i><span class="info-tip-bubble">Requires a TOTP code or hardware key at every sign-in. Disabling this immediately weakens workspace posture.</span></span></strong>
                <span>Require a second factor for every operator sign-in. Disabling this weakens the workspace posture immediately.</span>
              </div>
              <label class="switch" data-switch="twoFactor">
                <input type="checkbox" checked/>
                <span class="switch-track"><span class="switch-thumb"></span></span>
              </label>
            </div>
            <div class="switch-row">
              <div class="switch-info">
                <strong><span class="info-tip">Session approval for new devices<i class="info-tip-icon">i</i><span class="info-tip-bubble">First login from an unrecognised device triggers an approval step before workspace access is granted.</span></span></strong>
                <span>Prompt operators to approve sessions initiated from unrecognised devices before granting workspace access.</span>
              </div>
              <label class="switch" data-switch="sessionApproval">
                <input type="checkbox" checked/>
                <span class="switch-track"><span class="switch-thumb"></span></span>
              </label>
            </div>
            <div class="switch-row">
              <div class="switch-info">
                <strong><span class="info-tip">Webhook security alerts<i class="info-tip-icon">i</i><span class="info-tip-bubble">Sends auth anomalies and login spikes to a webhook endpoint before they hit the audit log — useful for Slack or PagerDuty.</span></span></strong>
                <span>Forward authentication anomalies and failed login spikes to the workspace webhook before they reach the audit log.</span>
              </div>
              <label class="switch" data-switch="webhookAlerts">
                <input type="checkbox"/>
                <span class="switch-track"><span class="switch-thumb"></span></span>
              </label>
            </div>
            <div class="switch-row">
              <div class="switch-info">
                <strong><span class="info-tip">Device trust scoring<i class="info-tip-icon">i</i><span class="info-tip-bubble">Rates session risk using device hygiene signals. Unmanaged or unknown devices get a lower score on write operations.</span></span></strong>
                <span>Weight session risk using device hygiene signals. Unmanaged endpoints receive a lower trust score during route-write operations.</span>
              </div>
              <label class="switch" data-switch="deviceTrust">
                <input type="checkbox" checked/>
                <span class="switch-track"><span class="switch-thumb"></span></span>
              </label>
            </div>
            <div class="switch-row">
              <div class="switch-info">
                <strong><span class="info-tip">Geo-anomaly alerts<i class="info-tip-icon">i</i><span class="info-tip-bubble">Flags logins from regions you don't normally access. Helps catch credential misuse early.</span></span></strong>
                <span>Flag sessions that originate from unexpected regions relative to the operator's usual access pattern.</span>
              </div>
              <label class="switch" data-switch="geoAlerts">
                <input type="checkbox"/>
                <span class="switch-track"><span class="switch-thumb"></span></span>
              </label>
            </div>
          </div>
        </article>

        <article class="settings-panel">
          <div class="panel-header">
            <div class="panel-kicker">Sessions</div>
            <h2 class="panel-title">Active sessions</h2>
            <p class="panel-desc">Every live session is visible here. Expire individual sessions or clear all to force re-authentication across the workspace.</p>
            <div class="panel-actions-inline">
              <button class="btn-secondary" data-expire-sessions="others">Expire other sessions</button>
              <button class="btn-secondary" data-expire-sessions="all">Expire all sessions</button>
            </div>
          </div>
          <div class="cards-list" data-sessions-list>
            <div class="session-card">
              <div class="session-meta">
                <strong>Loading active sessions...</strong>
                <span class="badge badge-neutral">Syncing</span>
              </div>
              <div class="session-detail">Session inventory is loading.</div>
            </div>
          </div>
        </article>

        <article class="settings-panel">
          <div class="panel-header">
            <div class="panel-kicker">Audit</div>
            <h2 class="panel-title">Recent activity</h2>
            <p class="panel-desc">A traceable record of authentication events, policy changes and session actions in this workspace.</p>
          </div>
          <div class="audit-list">
            <div class="audit-row">
              <div class="audit-time">Today, 09:14 UTC</div>
              <div class="audit-event">
                <strong>Session created</strong>
                <span>MacBook Pro — Safari 17 · EU Central</span>
              </div>
            </div>
            <div class="audit-row">
              <div class="audit-time">Today, 08:51 UTC</div>
              <div class="audit-event">
                <strong>Device trust score updated</strong>
                <span>iPhone 15 scored 94 / 100 after hygiene check</span>
              </div>
            </div>
            <div class="audit-row">
              <div class="audit-time">Yesterday, 22:03 UTC</div>
              <div class="audit-event">
                <strong>Session approval required</strong>
                <span>Linux — Chrome 122 approved from US East after device check</span>
              </div>
