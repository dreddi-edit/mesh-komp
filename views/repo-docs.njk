{% extends "layouts/base.njk" %}

{% block title %}Mesh Repo Docs{% endblock %}

{% block head %}
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Berkeley+Mono&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/assets/mesh-docs.css">
  <link rel="stylesheet" href="/assets/repo-docs.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark.min.css">
{% endblock %}


{% block content %}

  {% set activePage = "repo-docs" %}
  {% set siteNavShowRepoDocs = true %}
  {% include "partials/site-nav.njk" %}

  <div class="docs-shell">
    <aside class="docs-sidebar">
      <div class="side-title">Repository knowledge</div>
      <div class="repo-docs-brand">
        <h1>Codebase Explorer</h1>
        <p>Interactive docs for the current <code>mesh-komp</code> repository.</p>
      </div>

      <label class="repo-docs-search">
        <span>Filter files</span>
        <div class="repo-docs-search-wrap"><input id="repoDocsSearch" type="text" placeholder="Type to filter..." required><button type="button" id="repoDocsSearchClear" class="repo-docs-search-clear" aria-label="Clear search">×</button></div>
      </label>

      <div class="side-title">Key Docs</div>
      <nav id="repoDocsList" class="repo-docs-nav"></nav>

      <div class="side-title">Repository Map</div>
      <div id="repoTree" class="repo-tree"></div>
    </aside>

    <main class="docs-main">
      <header class="repo-docs-topbar">
        <div>
          <div class="repo-docs-topline">Live Repository Surface</div>
          <div id="repoDocsMeta" class="repo-docs-meta">Loading repo info...</div>
        </div>
      </header>

      <article class="repo-docs-content">
        <div id="repoDocsWelcome" class="repo-docs-welcome animate">
          <div class="eyebrow">mesh-komp</div>
          <h2>Interactive Code Surface</h2>
          <p>This page turns the current repository into a browsable knowledge base. Select a document or file from the left sidebar to render it with transport-level precision here.</p>
        </div>

        <div id="repoDocsContent" class="repo-docs-rendered" hidden></div>
      </article>

      {% include "partials/site-footer.njk" %}
    </main>
  </div>

  <script src="/assets/docs-shared.js"></script>
  <script src="/assets/repo-docs.js"></script>

{% endblock %}
