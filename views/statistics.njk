      <div class="section">
        <p class="section-label reveal">Überblick</p>
        <h2 class="section-title reveal reveal-delay-1">Dateiansichten und Recovery-Wege</h2>
        <div class="grid-cards">
          <div class="card reveal reveal-delay-1">
            <div class="icon-pill">V</div>
