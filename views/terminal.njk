{% extends "layouts/base.njk" %}

{% block title %}Terminal - Mesh{% endblock %}

{% block head %}
<link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Berkeley+Mono&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <script>
    (function() {
      var p = window.location.pathname;
      if (p.endsWith('.html')) {
        history.replaceState(null, '', p.replace(/\.html$/, '') + window.location.search + window.location.hash);
      }
    })();
  </script>
  <style>
    :root {
      --primary: #0f6a7b;
      --primary-deep: #123f5c;
      --secondary: #5f95a8;
      --tertiary: #1f496b;
      --surface: #f7fbfd;
      --surface-low: #ffffff;
      --surface-mid: #eef5f8;
      --ink: #102432;
      --ink-soft: #607787;
      --outline: #9bb0bc;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    body {
      background: var(--surface);
      color: var(--ink);
      font-family: "Inter", sans-serif;
      overflow-x: hidden;
    }

    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 450, 'GRAD' 0, 'opsz' 24;
      vertical-align: middle;
    }

    #bg-canvas {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      z-index: 1;
      pointer-events: none;
      opacity: 0.02;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    }

    /* ── Nav ── */
    .docs-nav {
      position: fixed;
      top: 16px;
      left: 50%;
      transform: translateX(-50%);
      right: auto;
      width: auto;
      max-width: 720px;
      height: auto;
      padding: 8px 8px 8px 20px;
      background: rgba(255, 255, 255, 0.06);
      backdrop-filter: blur(20px) saturate(150%);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 999px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.25);
      z-index: 100;
      display: flex;
      align-items: center;
      gap: 4px;
      transition: background 0.4s ease, border-color 0.4s ease, box-shadow 0.4s ease;
    }

    .nav-logo img {
      height: 20px;
      filter: brightness(0) invert(1);
      transition: filter 0.4s ease;
    }

    .nav-divider { width: 1px; height: 16px; background: rgba(255,255,255,0.2); margin: 0 6px; transition: background 0.4s; }

    .nav-links {
      display: flex;
      gap: 2px;
    }

    .nav-links a {
      font-size: 0.76rem;
      font-weight: 500;
      color: rgba(255, 255, 255, 0.6);
      padding: 6px 12px;
      border-radius: 999px;
      text-decoration: none;
      transition: color 0.2s, background 0.2s;
    }

    .nav-links a:hover {
      color: rgba(255, 255, 255, 0.95);
      background: rgba(255, 255, 255, 0.08);
    }

    .nav-links a.active {
      color: #fff;
      background: rgba(255, 255, 255, 0.1);
    }

    .nav-actions {
      display: flex;
      align-items: center;
      gap: 6px;
      margin-left: 4px;
    }

    .nav-btn-ghost {
      display: none;
    }

    .nav-btn-primary {
      font-size: 0.76rem;
      font-weight: 600;
      color: #fff;
      padding: 7px 16px;
      border-radius: 999px;
      background: rgba(15, 106, 123, 0.5);
      text-decoration: none;
      backdrop-filter: blur(10px);
      transition: background 0.2s;
    }

    .nav-btn-primary:hover {
      background: rgba(15, 106, 123, 0.7);
      opacity: 1;
      transform: none;
    }

    .docs-nav.scrolled {
      background: rgba(255, 255, 255, 0.82);
      backdrop-filter: blur(20px) saturate(180%);
      border-color: rgba(0, 0, 0, 0.06);
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    }

    .docs-nav.scrolled .nav-logo img {
      filter: none;
    }

    .docs-nav.scrolled .nav-links a {
      color: rgba(16, 36, 50, 0.55);
    }

    .docs-nav.scrolled .nav-links a:hover {
      color: #102432;
      background: rgba(15, 106, 123, 0.06);
    }

    .docs-nav.scrolled .nav-links a.active {
      color: #0f6a7b;
      background: rgba(15, 106, 123, 0.08);
    }

    .docs-nav.scrolled .nav-divider {
      background: rgba(0, 0, 0, 0.1) !important;
    }

    .docs-nav.scrolled .nav-btn-primary {
      background: linear-gradient(135deg, #0f6a7b, #123f5c);
    }

    /* ── Page shell ── */
    main { position: relative; z-index: 2; padding-top: 0; }

    .page-inner {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 24px 100px;
    }

    /* ── Hero ── */
    .hero {
      padding: 160px 24px 100px;
      margin-bottom: 64px;
      background: linear-gradient(180deg, #070e14 0%, #0d1f2d 50%, #1a3a4a 75%, #f7fbfd 100%);
      position: relative;
      overflow: hidden;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .hero::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 25%;
      background: linear-gradient(180deg, transparent, #f7fbfd);
      z-index: 3;
      pointer-events: none;
    }

    .hero-aurora {
      position: absolute;
      inset: -40% -20%;
      pointer-events: none;
      z-index: 0;
      filter: blur(70px);
      opacity: 0.6;
    }

    .aurora-band { position: absolute; border-radius: 50%; }
    .aurora-band-1 {
      width: 120%; height: 45%; top: -10%; left: -10%;
      background: radial-gradient(ellipse at 30% 50%, rgba(15,106,123,0.35) 0%, rgba(15,106,123,0.08) 40%, transparent 70%);
      animation: aurora-flow-1 16s ease-in-out infinite;
    }
    .aurora-band-2 {
      width: 90%; height: 50%; top: 20%; right: -15%;
      background: radial-gradient(ellipse at 70% 40%, rgba(31,73,107,0.3) 0%, rgba(95,149,168,0.1) 45%, transparent 70%);
      animation: aurora-flow-2 20s ease-in-out infinite;
    }
    .aurora-band-3 {
      width: 100%; height: 55%; bottom: -15%; left: 5%;
      background: radial-gradient(ellipse at 50% 60%, rgba(95,149,168,0.25) 0%, rgba(15,106,123,0.06) 50%, transparent 75%);
      animation: aurora-flow-3 22s ease-in-out infinite;
    }
    .aurora-band-4 {
      width: 70%; height: 35%; top: 30%; left: 15%;
      background: radial-gradient(ellipse at 40% 50%, rgba(15,106,123,0.2) 0%, rgba(31,73,107,0.08) 50%, transparent 70%);
      animation: aurora-flow-4 18s ease-in-out infinite;
    }

    @keyframes aurora-flow-1 {
      0%, 100% { transform: translate(0, 0) scale(1) rotate(0deg); }
      33% { transform: translate(8%, 5%) scale(1.12) rotate(2deg); }
      66% { transform: translate(-5%, -3%) scale(0.95) rotate(-1deg); }
    }
    @keyframes aurora-flow-2 {
      0%, 100% { transform: translate(0, 0) scale(1) rotate(0deg); }
      25% { transform: translate(-10%, 6%) scale(1.08) rotate(-2deg); }
      50% { transform: translate(5%, -4%) scale(0.92) rotate(1deg); }
      75% { transform: translate(-3%, 8%) scale(1.05) rotate(-1deg); }
    }
    @keyframes aurora-flow-3 {
      0%, 100% { transform: translate(0, 0) scale(1) rotate(0deg); }
      30% { transform: translate(6%, -5%) scale(1.1) rotate(1.5deg); }
      60% { transform: translate(-8%, 3%) scale(0.93) rotate(-2deg); }
    }
    @keyframes aurora-flow-4 {
      0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.6; }
      50% { transform: translate(12%, -8%) scale(1.15); opacity: 1; }
    }

    .hero .eyebrow {
      font-family: "Berkeley Mono", monospace;
      font-size: 0.62rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #72a9bf;
      margin-bottom: 16px;
      position: relative;
      z-index: 4;
    }

    .hero h1 {
      font-size: clamp(2.5rem, 5vw, 3.8rem);
      font-weight: 800;
      letter-spacing: -0.04em;
      line-height: 1.05;
      color: #fff;
      margin-bottom: 18px;
      position: relative;
      z-index: 4;
    }

    .hero p {
      font-size: 1.05rem;
      color: rgba(255, 255, 255, 0.6);
      line-height: 1.7;
      max-width: 640px;
      position: relative;
      z-index: 4;
    }

    /* ── Terminal hero panel ── */
    .terminal-hero {
      display: grid;
      grid-template-columns: 1.3fr 0.9fr;
      gap: 20px;
      margin-bottom: 56px;
    }

    .panel {
      background: var(--surface-low);
      border: 1px solid rgba(18,62,89,0.1);
      border-radius: 20px;
      padding: 24px;
      box-shadow: 0 8px 32px rgba(17,52,74,0.07);
    }

    /* ── Terminal display ── */
    .term-window {
      background: #0d1820;
      border-radius: 14px;
      overflow: hidden;
    }

    .term-bar {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 11px 16px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }

    .term-dots { display: flex; gap: 6px; }
    .term-dots span {
      width: 10px;
      height: 10px;
      border-radius: 50%;
    }
    .dot-red { background: #ff5f57; }
    .dot-yellow { background: #ffbd2e; }
    .dot-green { background: #28c840; }

    .term-title {
      font-family: "Berkeley Mono", monospace;
      font-size: 0.62rem;
      color: rgba(255,255,255,0.3);
      letter-spacing: 0.06em;
      margin-left: 4px;
    }

    .term-body {
      padding: 16px;
      font-family: "Berkeley Mono", monospace;
      font-size: 0.76rem;
      line-height: 1.75;
      color: #a8d8e8;
      min-height: 280px;
    }

    .t-line {
      display: block;
      opacity: 0;
      transform: translateY(4px);
      animation: line-in 0.38s ease forwards;
    }

    .t-primary { color: #7ef3c4; }
    .t-amber { color: #fbbf24; }
    .t-green { color: #4ade80; }
    .t-dim { color: rgba(168,216,232,0.35); }

    .t-cursor {
      display: inline-block;
      width: 7px;
      height: 13px;
      margin-left: 3px;
      background: var(--primary);
      vertical-align: text-bottom;
      animation: blink 1.1s step-end infinite;
    }

    @keyframes line-in {
      to { opacity: 1; transform: translateY(0); }
    }

    @keyframes blink {
      0%, 100% { opacity: 1; }
      50% { opacity: 0; }
    }

    /* ── Step list ── */
    .steps { display: flex; flex-direction: column; gap: 12px; }

    .step-item {
      padding: 14px 16px;
      background: var(--surface-mid);
      border: 1px solid rgba(18,62,89,0.1);
      border-radius: 12px;
    }

    .step-item h3 {
      font-size: 0.88rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      color: var(--ink);
      margin-bottom: 5px;
    }

    .step-item p {
      font-size: 0.8rem;
      color: var(--ink-soft);
      line-height: 1.6;
    }

    /* ── Section ── */
    .section { margin-bottom: 56px; }

    .section-label {
      font-family: "Berkeley Mono", monospace;
      font-size: 0.6rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--outline);
      margin-bottom: 10px;
    }

    .section-title {
      font-size: clamp(1.4rem, 2.5vw, 1.9rem);
      font-weight: 700;
      letter-spacing: -0.03em;
      color: var(--ink);
      margin-bottom: 28px;
      line-height: 1.2;
    }

    /* ── Feature cards ── */
    .grid-3 {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }

    .card {
      background: var(--surface-low);
      border: 1px solid rgba(18,62,89,0.1);
      border-radius: 18px;
      padding: 24px;
      box-shadow: 0 4px 20px rgba(17,52,74,0.05);
      transition: box-shadow 0.2s, transform 0.2s;
    }
    .card:hover { box-shadow: 0 8px 32px rgba(17,52,74,0.1); transform: translateY(-2px); }

    .card h4 {
      font-size: 0.92rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      color: var(--ink);
      margin-bottom: 8px;
    }

    .card p {
      font-size: 0.82rem;
      color: var(--ink-soft);
      line-height: 1.65;
    }

    /* ── Trace table ── */
    .trace {
      background: var(--surface-low);
      border: 1px solid rgba(18,62,89,0.1);
      border-radius: 18px;
      overflow: hidden;
      box-shadow: 0 4px 20px rgba(17,52,74,0.05);
    }

    .trace-header {
      padding: 18px 20px 0;
    }

    .trace-header h3 {
      font-size: 1rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      color: var(--ink);
      margin-bottom: 14px;
    }

    .trace-rows { display: flex; flex-direction: column; }

    .trace-row {
      display: grid;
      grid-template-columns: 200px 1fr 110px;
      gap: 12px;
      align-items: center;
      padding: 12px 20px;
      border-top: 1px solid rgba(18,62,89,0.07);
      transition: background 0.15s;
    }
    .trace-row:hover { background: rgba(15,106,123,0.03); }

    .trace-row:first-child { border-top: none; }

    .trace-file {
      font-family: "Berkeley Mono", monospace;
      font-size: 0.68rem;
      color: var(--primary);
      letter-spacing: 0.04em;
    }

    .trace-desc {
      font-size: 0.84rem;
      color: var(--ink-soft);
    }

    .trace-badge {
      font-family: "Berkeley Mono", monospace;
      font-size: 0.6rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--primary);
      border: 1px solid rgba(15,106,123,0.2);
      background: rgba(15,106,123,0.07);
      padding: 4px 8px;
      border-radius: 999px;
      text-align: center;
      white-space: nowrap;
    }

    /* ── Footer ── */
    footer { position: relative; z-index: 2; border-top: 1px solid rgba(18,62,89,0.12); padding: 36px 28px; }

    .footer-inner {
      max-width: 1100px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 20px;
      flex-wrap: wrap;
    }

    .footer-logo img { height: 16px; }

    .footer-links { display: flex; gap: 4px; flex-wrap: wrap; }

    .footer-links a {
      text-decoration: none;
      font-family: "Berkeley Mono", monospace;
      font-size: 0.62rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--outline);
      padding: 5px 10px;
      border-radius: 6px;
      transition: color 0.2s, background 0.2s;
    }
    .footer-links a:hover { color: var(--ink-soft); background: rgba(15,106,123,0.05); }

    .footer-copy {
      font-family: "Berkeley Mono", monospace;
      font-size: 0.58rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #91a6b3;
    }

    /* ── Reveal ── */
    .reveal {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.65s cubic-bezier(0.16,1,0.3,1), transform 0.65s cubic-bezier(0.16,1,0.3,1);
    }
    .reveal.visible { opacity: 1; transform: translateY(0); }
    .reveal-delay-1 { transition-delay: 0.08s; }
    .reveal-delay-2 { transition-delay: 0.16s; }

    @media (max-width: 900px) {
      .terminal-hero { grid-template-columns: 1fr; }
      .grid-3 { grid-template-columns: 1fr 1fr; }
      .trace-row { grid-template-columns: 1fr; }
      .trace-badge { width: fit-content; }
    }
    @media (max-width: 640px) {
      .nav-links { display: none; }
      .nav-btn-ghost { display: none; }
      .grid-3 { grid-template-columns: 1fr; }
    }
    @media (prefers-reduced-motion: reduce) {
      * { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; }
    }
  </style>
{% endblock %}


{% block content %}

  <canvas id="bg-canvas"></canvas>

  <nav class="docs-nav" id="navbar">
    <a class="nav-logo" href="index" aria-label="Mesh Startseite"><img src="/assets/brand/lockup-color.svg" alt="Mesh"/></a>
    <div class="nav-divider"></div>
    <div class="nav-links">
      <a href="index">Start</a>
      <a href="how-it-works">So funktioniert es</a>
      <a href="statistics">Statistiken</a>
      <a href="docs">Dokumentation</a>
      <a class="active" href="terminal">Terminal</a>
    </div>
    <div class="nav-actions">
      <a class="nav-btn-ghost" href="app?login=1">Anmelden</a>
      <a class="nav-btn-primary" href="app?login=1">Workspace</a>
    </div>
  </nav>

  <main>
    <header class="hero reveal">
      <div class="hero-aurora">
        <div class="aurora-band aurora-band-1"></div>
        <div class="aurora-band aurora-band-2"></div>
        <div class="aurora-band aurora-band-3"></div>
        <div class="aurora-band aurora-band-4"></div>
      </div>
      <div class="eyebrow">Operator-Ansicht</div>
      <h1>Terminal-Fluss: vom Upload bis zur verifizierten Antwort</h1>
      <p>Die Terminal-Perspektive zeigt den Ablauf Schritt für Schritt: Datei rein, kurz zusammenfassen, passende Stellen finden und bei Bedarf die Originalzeilen nachladen.</p>
    </header>

    <div class="page-inner">

      <div class="terminal-hero reveal reveal-delay-1">
        <div class="panel">
          <div class="term-window">
            <div class="term-bar">
              <div class="term-dots">
                <span class="dot-red"></span>
                <span class="dot-yellow"></span>
                <span class="dot-green"></span>
              </div>
              <span class="term-title">edgarbaumann@mesh-worker:~ — pipeline</span>
            </div>
            <div class="term-body">
              <span class="t-line" style="animation-delay:0.1s"><span class="t-primary">$</span> mesh workspace ingest ./src</span>
              <span class="t-line" style="animation-delay:0.35s">[manifest] 191 Dateien gefunden, 133 davon Textdateien</span>
              <span class="t-line" style="animation-delay:0.6s"><span class="t-dim">─────────────────────────────────────────────</span></span>
              <span class="t-line" style="animation-delay:0.85s">[index] Status pending für neue Workspace-Daten</span>
              <span class="t-line" style="animation-delay:1.1s">[capsule] Datei in kurze Abschnitte aufgeteilt</span>
              <span class="t-line" style="animation-delay:1.35s">[focused] Suche "auth middleware" <span class="t-amber">→</span> 8 passende Stellen</span>
              <span class="t-line" style="animation-delay:1.6s">[transport] sichere Übertragung mit v2-Format</span>
              <span class="t-line" style="animation-delay:1.85s">[recovery] Zeile 142 aus der Originaldatei geladen</span>
              <span class="t-line" style="animation-delay:2.1s"><span class="t-green">READY</span> Antwort mit Quellen bereit <span class="t-cursor" aria-hidden="true"></span></span>
            </div>
          </div>
        </div>

        <div class="panel">
          <div class="steps">
            <div class="step-item">
              <h3>1) Dateien sichtbar machen</h3>
              <p>Nach dem Öffnen des Workspaces zeigt Mesh die Dateien sofort an, auch wenn die Verarbeitung noch läuft.</p>
            </div>
            <div class="step-item">
              <h3>2) Kurz zusammenfassen</h3>
              <p>Die Datei wird in sinnvolle Abschnitte zerlegt, damit du nicht den kompletten Rohtext lesen musst.</p>
            </div>
            <div class="step-item">
              <h3>3) Passende Stellen finden</h3>
              <p>Mesh zeigt nur die Teile, die zu deiner Frage passen, statt die komplette Datei zu wiederholen.</p>
            </div>
            <div class="step-item">
              <h3>4) Originalstellen nachladen</h3>
              <p>Wenn es genau sein muss, lädt Mesh die exakten Zeilen oder Textbereiche aus der Quelle nach.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="section">
        <p class="section-label reveal">Überblick</p>
        <h2 class="section-title reveal reveal-delay-1">Schlüsselkonzepte im Betrieb</h2>
        <div class="grid-3">
          <div class="card reveal reveal-delay-1">
            <h4>Fehler sichtbar machen</h4>
            <p>Wenn etwas schiefgeht, bleibt der Fehlerstatus erhalten. So sieht man sofort, was noch einmal geprüft werden muss.</p>
          </div>
          <div class="card reveal reveal-delay-2">
            <h4>Sichere Übertragung</h4>
            <p>Prüfsummen helfen dabei, Datenfehler auf dem Weg durch das System zu erkennen.</p>
          </div>
          <div class="card reveal reveal-delay-1">
            <h4>Antworten mit Quellen</h4>
            <p>Die Antwort bleibt nachvollziehbar, weil Mesh die genauen Textstellen aus der Originaldatei nutzt.</p>
          </div>
        </div>
      </div>

      <div class="section">
        <p class="section-label reveal">Interner Ablauf</p>
        <h2 class="section-title reveal reveal-delay-1">Ablauf im Hintergrund</h2>
        <div class="trace reveal reveal-delay-1">
          <div class="trace-header">
            <h3>Aufrufkette</h3>
          </div>
          <div class="trace-rows">
            <div class="trace-row">
              <div class="trace-file">assistant-workspace.routes.js</div>
