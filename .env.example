# ──────────────────────────────────────────────────────────────────────────────
# Mesh Gateway — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# ──────────────────────────────────────────────────────────────────────────────

# ── Required in Production ────────────────────────────────────────────────────

NODE_ENV=development
# Set to "production" for production deployments. Controls security defaults,
# startup validation, and demo user availability.

MESH_DATA_ENCRYPTION_KEY=
# AES-256 encryption key for user session and store data.
# REQUIRED in production. In dev, a machine-derived fallback is used automatically.

MESH_COSMOS_ENDPOINT=
# Azure Cosmos DB endpoint URL (e.g. https://your-account.documents.azure.com:443/).
# REQUIRED in production. Without Cosmos DB, an in-memory store is used (data lost on restart).

MESH_COSMOS_KEY=
# Azure Cosmos DB primary key.
# REQUIRED in production.

MESH_COSMOS_DATABASE=mesh-db
# Cosmos DB database name. Defaults to "mesh-db".

# ── AI Providers (optional) ───────────────────────────────────────────────────

ANTHROPIC_API_KEY=
# Anthropic API key for Claude models. Required for chat and assistant features.

AZURE_OPENAI_ENDPOINT=
# Azure OpenAI endpoint for inline completion and streaming chat.

AZURE_OPENAI_KEY=
# Azure OpenAI API key.

OPENAI_API_KEY=
# OpenAI API key (direct, non-Azure).

GOOGLE_API_KEY=
# Google Gemini API key.

# ── Voice (optional) ──────────────────────────────────────────────────────────

AZURE_OPENAI_VOICE_ENDPOINT=
# Azure OpenAI endpoint for voice features (transcription, TTS, text orchestration).

AZURE_OPENAI_VOICE_KEY=
# Azure OpenAI key for voice deployments.

# AZURE_OPENAI_VOICE_TRANSCRIBE_DEPLOYMENT=gpt-4o-mini-transcribe
# AZURE_OPENAI_VOICE_TEXT_DEPLOYMENT=gpt-5.4-nano
# AZURE_OPENAI_VOICE_TTS_DEPLOYMENT=gpt-4o-mini-tts
# AZURE_OPENAI_VOICE_TTS_VOICE=alloy

# ── Auth & Cookies (optional, sensible defaults) ─────────────────────────────

# MESH_AUTH_COOKIE_NAME=mesh_auth
# MESH_AUTH_COOKIE_PATH=/
# MESH_AUTH_COOKIE_SAMESITE=Strict
# MESH_AUTH_COOKIE_SECURE=true
# Set MESH_AUTH_COOKIE_SECURE=false for local HTTP development.

# ── Demo User ─────────────────────────────────────────────────────────────────

# MESH_DEMO_USER_ENABLED=true
# Enables the demo user (edgar@test.com / 12345).
# Default: true in development, false in production.
# Set explicitly to override the default.

# MESH_DEMO_USER_EMAIL_ALIASES=
# Comma-separated list of additional emails accepted for demo login.

# ── Server ────────────────────────────────────────────────────────────────────

PORT=8080
# HTTP server port.

# MESH_CORE_URL=http://localhost:8080/mesh/tunnel
# URL of the Mesh Core worker for tunneled requests.

# MESH_TERMINAL_UPLOAD_ROOT=
# Directory for materialized uploaded workspaces. Defaults to OS temp dir.

# ── Azure Blob Storage (optional, for workspace offload) ─────────────────────

# MESH_AZURE_OFFLOAD_ENABLED=false
# MESH_AZURE_BLOB_BASE_URL=
# MESH_AZURE_BLOB_CONTAINER=
# MESH_AZURE_BLOB_SAS_TOKEN=
# MESH_AZURE_BLOB_UPLOAD_SAS_TOKEN=
# MESH_AZURE_BLOB_READ_SAS_TOKEN=
# MESH_AZURE_BLOB_DELETE_SAS_TOKEN=
