# ──────────────────────────────────────────────────────────────────────────────
# Mesh Gateway — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# ──────────────────────────────────────────────────────────────────────────────

# ── Required in Production ────────────────────────────────────────────────────

NODE_ENV=development
# Set to "production" for production deployments. Controls security defaults,
# startup validation, and demo user availability.

MESH_DATA_ENCRYPTION_KEY=
# AES-256 encryption key for user session and store data.
# REQUIRED in production. In dev, a machine-derived fallback is used automatically.
# WARNING: Never rotate this key — rotating it makes all existing encrypted rows unreadable.

MESH_SECURE_DB_FILE=
# Path to the encrypted SQLite database file.
# REQUIRED in production. Must be on persistent storage (e.g. /home/data/mesh-secure-v2.db).
# In development, defaults to a local file in the project root.

# ── AWS DynamoDB (replaces Cosmos DB for user/session storage) ────────────────

MESH_DYNAMO_ENABLED=false
# Set to "true" to use DynamoDB for user, session, and store records.
# Without DynamoDB, an in-memory store is used (data lost on restart).

MESH_DYNAMO_TABLE_PREFIX=mesh
# Prefix for DynamoDB table names. Default: "mesh"
# Creates: mesh-users, mesh-sessions, mesh-stores (or use explicit vars below).

# MESH_DYNAMO_USERS_TABLE=mesh-users
# MESH_DYNAMO_SESSIONS_TABLE=mesh-sessions
# MESH_DYNAMO_STORES_TABLE=mesh-stores
# Override individual table names if the prefix convention doesn't fit.

# Required GSIs:
#   mesh-users: email-index (email → userId), userId-index (userId → items)
#   mesh-sessions: userId-index (userId → sessions)
#   mesh-stores: userId-index (userId → store rows)
# All tables require native TTL enabled on the "ttl" attribute.

# ── AI Providers ──────────────────────────────────────────────────────────────

ANTHROPIC_API_KEY=
# Anthropic API key for Claude models. Alternative to AWS Bedrock credentials below.

# ── AWS Bedrock (preferred for Claude models) ─────────────────────────────────

AWS_ACCESS_KEY_ID=
# IAM user access key with AmazonBedrockFullAccess.
# Takes priority over ANTHROPIC_API_KEY for claude-* models.
# Leave blank to use IAM role / instance profile credentials automatically.

AWS_SECRET_ACCESS_KEY=
# IAM user secret key paired with AWS_ACCESS_KEY_ID.

AWS_REGION_BEDROCK=us-east-1
# AWS region for Bedrock inference profiles. Default: us-east-1.

MESH_DEFAULT_MODEL=claude-sonnet-4-6
# Default model for chat and assistant.

OPENAI_API_KEY=
# OpenAI API key (direct, user-supplied BYOK).

GOOGLE_API_KEY=
# Google Gemini API key.

# ── Voice — Amazon Transcribe + Polly (AWS-native) ───────────────────────────

# MESH_VOICE_TRANSCRIBE_LANGUAGE=en-US
# Language code for Amazon Transcribe Streaming. Default: en-US

# MESH_VOICE_POLLY_VOICE=Joanna
# Amazon Polly voice ID. Default: Joanna (neural)
# See: https://docs.aws.amazon.com/polly/latest/dg/voicelist.html

# MESH_VOICE_POLLY_ENGINE=neural
# Polly engine: "neural" or "standard". Default: neural

# ── Voice VAD tuning (optional) ───────────────────────────────────────────────

# MESH_VOICE_VAD_THRESHOLD=0.012
# MESH_VOICE_VAD_PREFIX_MS=240
# MESH_VOICE_VAD_SILENCE_MS=720
# MESH_VOICE_MIN_UTTERANCE_MS=280
# MESH_VOICE_MAX_UTTERANCE_MS=14000

# ── Auth & Cookies (optional, sensible defaults) ──────────────────────────────

# MESH_AUTH_COOKIE_NAME=mesh_auth
# MESH_AUTH_COOKIE_PATH=/
# MESH_AUTH_COOKIE_SAMESITE=Strict
# MESH_AUTH_COOKIE_SECURE=true
# Set MESH_AUTH_COOKIE_SECURE=false for local HTTP development.

# ── Demo User ─────────────────────────────────────────────────────────────────

# MESH_DEMO_USER_ENABLED=true
# Enables the in-memory demo user. Default: true in development, false in production.

# MESH_DEMO_USER_EMAIL=edgar@test.com
# Email address for the demo user account.

# MESH_DEMO_USER_PASSWORD=12345
# Password for the demo user account.

# MESH_DEMO_USER_EMAIL_ALIASES=
# Comma-separated list of additional emails accepted for demo login.

# ── Server ────────────────────────────────────────────────────────────────────

PORT=8080
# HTTP server port.

# MESH_CORE_URL=http://localhost:8080/mesh/tunnel
# URL of the Mesh Core worker for tunneled requests.

# MESH_TERMINAL_UPLOAD_ROOT=
# Directory for materialized uploaded workspaces. Defaults to OS temp dir.

# ── S3 Blob Storage (optional, for workspace offload) ─────────────────────────

# MESH_S3_OFFLOAD_ENABLED=false
# Set to "true" to offload workspace blobs to S3 instead of local disk.

# MESH_S3_BUCKET=
# S3 bucket name for workspace blob storage.

# MESH_S3_PREFIX=
# Key prefix within the bucket (e.g. "workspace/"). No trailing slash needed.

# MESH_S3_OFFLOAD_MAX_CHUNK_FILES=900
# MESH_S3_OFFLOAD_MAX_CHUNK_BYTES=60000000
# MESH_S3_OFFLOAD_MAX_PARALLEL_READS=64
# MESH_S3_OFFLOAD_MAX_INFLIGHT_CHUNKS=4
